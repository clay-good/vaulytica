{
  "name": "vaulytica",
  "version": "9.30.0",
  "private": true,
  "description": "The free, deterministic, runs-entirely-in-your-browser contract checker. A linter for legal documents.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "legal",
    "contract",
    "linter",
    "deterministic",
    "sarif",
    "ci",
    "redline",
    "compliance"
  ],
  "homepage": "https://vaulytica.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clay-good/vaulytica.git"
  },
  "bugs": {
    "url": "https://github.com/clay-good/vaulytica/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "vaulytica": "bin/vaulytica.mjs"
  },
  "files": [
    "bin/",
    "tools/cli/",
    "tools/accuracy/",
    "src/",
    "dkb/dist/v0.0.1-starter/",
    "playbooks/",
    "tsconfig.json",
    "!**/*.test.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "dkb:fetch": "tsx dkb/build/run-fetcher.ts",
    "dkb:build": "tsx dkb/build/build.ts",
    "icons": "tsx tools/generate-icons.ts",
    "screenshots": "playwright test tools/screenshots/capture.spec.ts --config=tools/screenshots/pw.config.ts",
    "playbooks:bundle": "tsx tools/build-extended-playbooks.ts",
    "accuracy": "tsx tools/accuracy/run.ts",
    "citation:check": "tsx tools/citation-check/run.ts",
    "cli": "tsx tools/cli/run.ts",
    "analyze": "tsx tools/cli/run.ts",
    "fixtures": "tsx tests/fixtures/build-fixtures.ts",
    "fixtures:baa": "tsx tests/fixtures/build-baa-fixture.ts",
    "fixtures:regen-golden": "VAULYTICA_REGEN_GOLDEN=1 vitest run tests/integration/golden-output.test.ts",
    "mutation": "stryker run",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "docx": "^9.6.1",
    "fflate": "^0.8.3",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^6.0.227",
    "tesseract.js": "^5.1.0",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.8",
    "@xmldom/xmldom": "^0.9.10",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.2.5",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "qs": "^6.15.2"
  }
}
