{
  "name": "vaulytica",
  "version": "6.0.0",
  "private": true,
  "description": "The free, deterministic, runs-entirely-in-your-browser contract checker. A linter for legal documents.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "dkb:fetch": "tsx dkb/build/run-fetcher.ts",
    "dkb:build": "tsx dkb/build/build.ts",
    "icons": "tsx tools/generate-icons.ts",
    "playbooks:bundle": "tsx tools/build-extended-playbooks.ts",
    "accuracy": "tsx tools/accuracy/run.ts",
    "fixtures": "tsx tests/fixtures/build-fixtures.ts",
    "fixtures:baa": "tsx tests/fixtures/build-baa-fixture.ts",
    "fixtures:regen-golden": "VAULYTICA_REGEN_GOLDEN=1 vitest run tests/integration/golden-output.test.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "docx": "^9.6.1",
    "fflate": "^0.8.3",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.2.67",
    "tesseract.js": "^5.1.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.19",
    "@xmldom/xmldom": "^0.9.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.2.5",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
