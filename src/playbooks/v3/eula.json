{
  "id": "eula",
  "version": "1.0.0",
  "name": "End-User License Agreement (EULA)",
  "description": "Linter for an End-User License Agreement / Software License Agreement. Selects the §34 addenda ruleset (EULA portion, ADDENDA-017..018): explicit license grant scope + prohibited-uses enumeration, EU consumer-law minimums (Digital Content Directive 2019/770 + Consumer Rights Directive 2011/83).",
  "match_features": {
    "title_keywords": [
      "end user license agreement",
      "end-user license agreement",
      "eula",
      "software license agreement",
      "application license agreement"
    ],
    "required_clauses": [],
    "distinguishing_phrases": [
      "license to use",
      "non-exclusive",
      "non-transferable",
      "reverse engineer",
      "sublicense",
      "decompile",
      "software"
    ],
    "negative_features": [
      "protected health information",
      "data processing agreement",
      "master services agreement"
    ]
  },
  "expected_clauses": [
    "License Grant",
    "Prohibited Uses",
    "Ownership",
    "Updates and Versions",
    "Support and Disclaimers",
    "Termination"
  ],
  "expected_defined_terms": [
    "Software",
    "Documentation",
    "Licensee",
    "Licensor"
  ],
