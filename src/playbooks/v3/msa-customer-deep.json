{
  "id": "msa-customer-deep",
  "version": "1.0.0",
  "name": "MSA — Customer-Side Deep Analysis",
  "description": "Deep analysis of a Master Services Agreement (or Master Subscription Agreement) from the customer's perspective. Selects the §33 MSA-deep ruleset (30 rules). Replaces v2's saas-customer playbook. Oriented toward catching customer-unfriendly drafting: no security commitments, missing SLA, broad assignment rights, no data return on termination, indemnity carved out of the cap, sole-and-exclusive SLA credit remedy, missing wind-down period.",
  "match_features": {
    "title_keywords": [
      "master services agreement",
      "master subscription agreement",
      "master agreement",
      "customer agreement",
      "cloud service agreement",
      "saas agreement",
      "subscription terms"
    ],
    "required_clauses": [],
    "distinguishing_phrases": [
      "service level agreement",
      "uptime",
      "data return",
      "customer data",
      "termination for convenience",
      "transition assistance",
      "limitation of liability",
      "indemnification",
      "order of precedence"
    ],
    "negative_features": [
      "protected health information",
      "personal data of data subjects",
      "non-disclosure agreement",
      "this nda"
    ]
  },
  "expected_clauses": [
    "Service Levels",
    "Data Protection",
    "Limitation of Liability",
    "Indemnification",
    "Termination",
    "Data Return",
    "Order of Precedence",
    "Confidentiality",
    "Governing Law"
  ],
  "expected_defined_terms": [
    "Agreement",
    "Services",
    "Customer Data",
    "Confidential Information",
    "Order Form",
    "Affiliate",
    "Fees"
  ],
