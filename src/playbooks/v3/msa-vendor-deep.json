{
  "id": "msa-vendor-deep",
  "version": "1.0.0",
  "name": "MSA — Vendor-Side Deep Analysis",
  "description": "Deep analysis of a Master Services Agreement (or Master Subscription Agreement) from the vendor's perspective. Selects the §33 MSA-deep ruleset (30 rules). Replaces v2's saas-vendor playbook and overlaps msa-general for vendor-side review. Oriented toward catching vendor-friendly drafting that may not survive customer review: low liability caps, broad disclaimers, narrow indemnities, broad limitation of liability, unbounded feedback license, AI-usage non-disclosure.",
  "match_features": {
    "title_keywords": [
      "master services agreement",
      "master subscription agreement",
      "master agreement",
      "vendor agreement",
      "cloud service agreement",
      "saas agreement"
    ],
    "required_clauses": [],
    "distinguishing_phrases": [
      "limitation of liability",
      "indemnification",
      "intellectual property",
      "warranty",
      "term and termination",
      "force majeure",
      "service level",
      "order of precedence",
      "statement of work",
      "fees and payment",
      "professional services"
    ],
    "negative_features": [
      "protected health information",
      "personal data of data subjects",
      "non-disclosure agreement",
      "this nda"
    ]
  },
  "expected_clauses": [
    "Limitation of Liability",
    "Indemnification",
    "Intellectual Property",
    "Warranties",
    "Term and Termination",
    "Order of Precedence",
    "Confidentiality",
    "Governing Law"
  ],
  "expected_defined_terms": [
    "Agreement",
    "Services",
    "Deliverables",
    "Confidential Information",
    "Statement of Work",
    "Affiliate",
    "Fees"
  ],
