  "findings": [
    {
      "description": "Neither 'indemnify' nor 'hold harmless' appears in the document.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no indemnification language)"
      },
      "explanation": "Most commercial contracts allocate risk through an indemnification clause. The absence leaves the parties to default tort and contract law for any third-party claims.",
      "id": "RISK-001-s1-0",
      "rule_id": "RISK-001",
      "rule_version": "1.0.0",
      "severity": "critical",
      "source_citations": [],
      "title": "No indemnification clause detected"
    },
    {
      "description": "Notice window: 90 days, located in s1.4.",
      "document_position": 1175,
      "excerpt": {
        "end_offset": 1197,
        "section_id": "s1.4",
        "start_offset": 1175,
        "text": "Subscription Term: one (1) year, renewing automatically for successive one-year terms unless Customer provides written notice of non-renewal by certified mail to Vendor's General Counsel no fewer than"
      },
      "explanation": "When the non-renewal notice window is in a different section from the auto-renewal clause or longer than 90 days, customers commonly miss it. FTC negative-option guidance (16 CFR Part 425) addresses this pattern.",
      "id": "DARK-002-s1.4-1175",
      "rule_id": "DARK-002",
      "rule_version": "1.1.0",
      "severity": "warning",
      "source_citations": [
        {
          "id": "stat-16-cfr-425",
          "license": "Public domain (US government work)",
          "license_url": "https://www.usa.gov/government-works",
          "retrieved_at": "2026-05-11T00:00:00Z",
          "source": "16 C.F.R. Part 425 (FTC Negative Option Rule)",
          "source_url": "https://www.ecfr.gov/current/title-16/chapter-I/subchapter-D/part-425"
        }
      ],
      "title": "Auto-renewal with notice window buried or long"
    },
    {
      "description": "Vendor may suspend Customer's access to the Services, in whole or in part, immediately and without notice if Vendor determines in its sole discretion",
      "document_position": 144,
      "excerpt": {
        "end_offset": 293,
        "section_id": "s1.1",
        "start_offset": 144,
        "text": "Vendor may suspend Customer's access to the Services, in whole or in part, immediately and without notice if Vendor determines in its sole discretion that Customer has breached this Agreement or that continued access poses a risk to Vendor or its other customers."
      },
      "explanation": "Broad suspension rights without notice or a cure period are widely recognized as a collection-leverage dark pattern in SaaS: a single disputed invoice can shut down a customer's production systems. Best-practice drafting limits suspension to material, unremedied breach after written notice and a defined cure window, and excludes invoices the customer is disputing in good faith.",
      "id": "DARK-008-s1.1-144",
      "recommendation": "Negotiate: (1) written notice of the alleged breach, (2) a cure period (typically 10–30 days), (3) an exclusion for disputed invoices, (4) carve-outs for security-incident response. Vendor's tools to manage non-payment are termination and interest, not suspension.",
      "rule_id": "DARK-008",
      "rule_version": "1.1.0",
      "severity": "warning",
      "source_citations": [
        {
          "id": "stat-ftc-deception-statement",
          "license": "Public domain (US government work)",
          "license_url": "https://www.usa.gov/government-works",
          "retrieved_at": "2026-05-11T00:00:00Z",
          "source": "FTC Policy Statement on Deception (1983)",
          "source_url": "https://www.ftc.gov/legal-library/browse/ftc-policy-statement-deception"
        }
      ],
      "title": "Unilateral suspension without notice or cure"
