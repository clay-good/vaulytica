    {
      "description": "The document does not state where disputes must be brought.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no venue clause)"
      },
      "explanation": "Without a venue clause, default venue rules apply (in federal court, 28 U.S.C. § 1391). A clear forum-selection clause avoids ambiguity.",
