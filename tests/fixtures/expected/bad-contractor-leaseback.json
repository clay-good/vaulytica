  "findings": [
    {
      "description": "An IP assignment is present but pre-existing IP is not expressly carved out.",
      "document_position": 855,
      "excerpt": {
        "end_offset": 941,
        "section_id": "s1.3",
        "start_offset": 855,
        "text": "Contractor hereby irrevocably assigns to Company all right, title, and interest, including all intellectual property rights, in and to any and all works, inventions, methods, processes, software, and materials created, conceived, developed, or used by Contractor in connection wit"
      },
      "explanation": "Without an explicit carve-out, a broad assignment can sweep in the assigning party's pre-existing IP. Modern drafting carves out 'Background IP' or 'Pre-existing IP' to scope the assignment.",
      "id": "IPDATA-002-s1.3-855",
      "rule_id": "IPDATA-002",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [],
      "title": "Pre-existing IP carve-out not stated"
    },
    {
      "description": "Vaulytica did not find a limitation-of-liability clause.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no LoL clause)"
      },
      "explanation": "Without a limitation-of-liability clause, exposure is bounded only by what the parties can prove in damages. Most commercial contracts cap liability.",
      "id": "RISK-005-s1-0",
      "rule_id": "RISK-005",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [],
      "title": "No limitation-of-liability clause detected"
    },
    {
      "description": "No Effective Date is named, defined, or stated near the top of this Agreement.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no Effective Date reference matched)"
      },
      "explanation": "Most contracts identify a starting point that other date references rely on. Without it, relative terms like 'within 30 days after the Effective Date' have no anchor.",
      "id": "STRUCT-002-s1-0",
      "recommendation": "Add an Effective Date — either in the preamble ('dated as of [date]'), as a defined term, or as an explicit 'Effective Date: [date]' line.",
      "rule_id": "STRUCT-002",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [],
      "title": "No Effective Date found"
    },
    {
      "description": "Used but not defined: Driver Owner.",
      "document_position": 130,
      "excerpt": {
        "end_offset": 142,
        "section_id": "s1",
        "start_offset": 130,
        "text": "Driver Owner"
      },
      "explanation": "Title-Case phrases in a contract usually signal a defined term. When they aren't defined, readers must guess at the intended meaning. Either define them or use lowercase if the term is intended in its ordinary sense.",
      "id": "STRUCT-006-s1-130",
      "recommendation": "Add a definition for each genuinely defined term, or change the casing if the phrase is being used in its ordinary sense.",
      "rule_id": "STRUCT-006",
      "rule_version": "1.1.0",
      "severity": "warning",
      "source_citations": [],
      "title": "Undefined Title-Case terms: 1"
    },
    {
      "description": "The contract does not state what happens upon termination.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no effect-of-termination clause)"
      },
      "explanation": "An effect-of-termination clause spells out the rights and obligations that survive, the return or destruction of materials, and the wind-down rules.",
      "id": "TERM-005-s1-0",
      "rule_id": "TERM-005",
      "rule_version": "1.2.0",
      "severity": "warning",
      "source_citations": [],
      "title": "No effect-of-termination clause detected"
    },
    {
      "description": "The document does not state where disputes must be brought.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no venue clause)"
      },
      "explanation": "Without a venue clause, default venue rules apply (in federal court, 28 U.S.C. § 1391). A clear forum-selection clause avoids ambiguity.",
