  "findings": [
    {
      "description": "The contract does not allocate ownership of intellectual property.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no IP-ownership clause)"
      },
      "explanation": "Without an IP-ownership clause, default copyright and patent rules apply: under 17 U.S.C. § 201, copyright vests in the author/employee unless work-for-hire or assignment applies.",
      "id": "IPDATA-001-s1-0",
      "rule_id": "IPDATA-001",
      "rule_version": "1.2.0",
      "severity": "warning",
      "source_citations": [
        {
          "id": "stat-17-usc-101",
          "license": "Public domain (US government work)",
          "license_url": "https://www.usa.gov/government-works",
          "retrieved_at": "2026-05-11T00:00:00Z",
          "source": "17 U.S.C. § 101 — Definitions (work made for hire)",
          "source_url": "https://www.law.cornell.edu/uscode/text/17/101"
        },
        {
          "id": "stat-17-usc-201",
          "license": "Public domain (US government work)",
          "license_url": "https://www.usa.gov/government-works",
          "retrieved_at": "2026-05-11T00:00:00Z",
          "source": "17 U.S.C. § 201",
          "source_url": "https://www.law.cornell.edu/uscode/text/17/201"
        }
      ],
      "title": "No IP-ownership clause detected"
    },
    {
      "description": "shall not directly or indirectly compete",
      "document_position": 910,
      "excerpt": {
        "end_offset": 950,
        "section_id": "s1.5",
        "start_offset": 910,
        "text": "months thereafter, Consultant shall not directly or indirectly compete with Customer or perform services for any other party within the State of California."
      },
      "explanation": "Non-compete clauses have sharply divergent enforceability by jurisdiction. California prohibits them outright (Bus. & Prof. Code § 16600); Washington imposes income thresholds; Texas requires consideration and a reasonable geographic / temporal scope under Bus. & Com. Code § 15.50; the FTC's nationwide ban was vacated in 2024 but the regulatory environment remains active. A non-compete that's standard in one state may be void in another.",
      "id": "PERS-005-s1.5-910",
      "recommendation": "Confirm the controlling jurisdiction's enforceability bucket (use the DKB jurisdiction record). If the controlling state voids non-competes, either delete the clause or convert to a narrower non-solicitation. If the clause is enforceable, audit the duration, geographic scope, and consideration provided.",
      "rule_id": "PERS-005",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [
        {
          "id": "stat-ca-bp-16600",
          "license": "Public domain (US government work)",
          "license_url": "https://www.usa.gov/government-works",
          "retrieved_at": "2026-05-11T00:00:00Z",
          "source": "California Business and Professions Code § 16600",
          "source_url": "https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?lawCode=BPC&sectionNum=16600."
        }
      ],
      "title": "Non-compete clause present"
    },
    {
      "description": "shall not disparage",
      "document_position": 1069,
      "excerpt": {
        "end_offset": 1088,
        "section_id": "s1.6",
        "start_offset": 1069,
        "text": "Consultant shall not disparage Customer, its officers, or its products in any public or private communication."
      },
      "explanation": "A non-disparagement clause that binds an employee or contractor at separation is enforceable in most US jurisdictions, but the NLRB's *McLaren Macomb* decision (Feb 2023) held that broad non-disparagement language in severance agreements can be unlawful as to NLRA-protected concerted activity. The SEC's Rule 21F-17 separately voids clauses that would prevent whistleblowing to the Commission. A non-disparagement provision without carve-outs for protected speech / agency reports / truthful testimony is increasingly indefensible.",
