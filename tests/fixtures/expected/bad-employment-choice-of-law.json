  "findings": [
    {
      "description": "Worker / party is identified as California-based but the contract selects Delaware law.",
      "document_position": 840,
      "excerpt": {
        "end_offset": 918,
        "section_id": "s1.3",
        "start_offset": 840,
        "text": "Delaware"
      },
      "explanation": "Cal. Lab. Code § 925 voids out-of-state choice-of-law clauses in employment contracts entered into, modified, or extended after Jan. 1, 2017 — unless the employee was individually represented by counsel in negotiating that specific clause. Cal. Bus. & Prof. Code § 16600.5 (2024) extends similar reasoning to non-competes: they are unenforceable regardless of where signed if the worker is in California, and create a private right of action with attorneys' fees. This pattern is commonly used to evade California's strict non-compete prohibitions; courts (e.g., *Lyon v. Neustar*) routinely refuse to enforce it.",
      "id": "CHOICE-011-s1.3-840",
      "recommendation": "Either change governing law to California, or include a §925 counsel-representation acknowledgment. Note that §16600.5 may render any non-compete unenforceable even with §925-compliant choice-of-law language.",
      "rule_id": "CHOICE-011",
      "rule_version": "1.1.0",
      "severity": "warning",
      "source_citations": [
        {
          "id": "stat-ca-bp-16600",
          "license": "Public domain (US government work)",
          "license_url": "https://www.usa.gov/government-works",
          "retrieved_at": "2026-05-11T00:00:00Z",
          "source": "California Business and Professions Code § 16600",
          "source_url": "https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?lawCode=BPC&sectionNum=16600."
        }
      ],
      "title": "Out-of-state choice-of-law on California-based party"
    },
    {
      "description": "shall not directly or indirectly compete",
      "document_position": 704,
      "excerpt": {
        "end_offset": 744,
        "section_id": "s1.2",
        "start_offset": 704,
        "text": "llowing termination, Employee shall not directly or indirectly compete with Company anywhere within North America."
      },
      "explanation": "Non-compete clauses have sharply divergent enforceability by jurisdiction. California prohibits them outright (Bus. & Prof. Code § 16600); Washington imposes income thresholds; Texas requires consideration and a reasonable geographic / temporal scope under Bus. & Com. Code § 15.50; the FTC's nationwide ban was vacated in 2024 but the regulatory environment remains active. A non-compete that's standard in one state may be void in another.",
      "id": "PERS-005-s1.2-704",
      "recommendation": "Confirm the controlling jurisdiction's enforceability bucket (use the DKB jurisdiction record). If the controlling state voids non-competes, either delete the clause or convert to a narrower non-solicitation. If the clause is enforceable, audit the duration, geographic scope, and consideration provided.",
      "rule_id": "PERS-005",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [
        {
          "id": "stat-ca-bp-16600",
          "license": "Public domain (US government work)",
          "license_url": "https://www.usa.gov/government-works",
          "retrieved_at": "2026-05-11T00:00:00Z",
          "source": "California Business and Professions Code § 16600",
          "source_url": "https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?lawCode=BPC&sectionNum=16600."
        }
      ],
      "title": "Non-compete clause present"
    },
    {
      "description": "Neither 'indemnify' nor 'hold harmless' appears in the document.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no indemnification language)"
      },
      "explanation": "Most commercial contracts allocate risk through an indemnification clause. The absence leaves the parties to default tort and contract law for any third-party claims.",
      "id": "RISK-001-s1-0",
      "rule_id": "RISK-001",
