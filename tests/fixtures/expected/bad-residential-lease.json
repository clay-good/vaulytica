  "findings": [
    {
      "description": "Found 1 placeholder that looks like unfilled template content: \"[Property Address]\".",
      "document_position": 170,
      "excerpt": {
        "end_offset": 188,
        "section_id": "s1",
        "start_offset": 170,
        "text": "[Property Address]"
      },
      "explanation": "A bracketed placeholder, mustache token, or XXX run that survived into the final document is almost always a drafting accident — the contract is meant to be filled in. A placeholder where a counterparty name belongs makes the agreement legally questionable; a placeholder elsewhere makes the agreement embarrassing.",
      "id": "STRUCT-013-s1-170",
      "recommendation": "Replace every flagged placeholder with the intended content, or remove the bracket if the content is no longer needed.",
      "rule_id": "STRUCT-013",
      "rule_version": "1.0.0",
      "severity": "critical",
      "source_citations": [],
      "title": "Unfilled template placeholders: 1"
    },
    {
      "description": "Tenant shall provide Landlord at least 30 days written notice of any claim before initiating suit",
      "document_position": 810,
      "excerpt": {
        "end_offset": 907,
        "section_id": "s1.5",
        "start_offset": 810,
        "text": "Tenant shall provide Landlord at least 30 days written notice of any claim before initiating suit."
      },
      "explanation": "A pre-suit notice or cure window imposed on one party (typically the consumer / customer / employee) but not on the drafter compresses the affected party's ability to act quickly — by the time the notice period expires, evidence has aged and pressure to settle has built. The drafter, meanwhile, can initiate proceedings without warning. Confirm whether the asymmetry is a legitimate dispute-resolution structure (e.g., an MSA's `cure for material breach` provision) or a one-sided friction gate.",
      "id": "DARK-006-s1.5-810",
      "recommendation": "If the gate is meant as a dispute-cooling mechanism, make it bilateral (`each party shall provide…`). If it is a one-sided cure window for the drafter's benefit, weigh whether the trade is intended.",
      "rule_id": "DARK-006",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [
        {
          "id": "stat-ftc-deception-statement",
          "license": "Public domain (US government work)",
          "license_url": "https://www.usa.gov/government-works",
          "retrieved_at": "2026-05-11T00:00:00Z",
          "source": "FTC Policy Statement on Deception (1983)",
          "source_url": "https://www.ftc.gov/legal-library/browse/ftc-policy-statement-deception"
        }
      ],
      "title": "Asymmetric pre-suit notice / cure window"
    },
    {
      "description": "deemed to have agreed",
      "document_position": 744,
      "excerpt": {
        "end_offset": 765,
        "section_id": "s1.4",
        "start_offset": 744,
        "text": "cy of the Premises, Tenant is deemed to have agreed to all updated Terms."
      },
      "explanation": "Browsewrap acceptance — `by using the Service you agree`, `continued use constitutes acceptance`, `you are deemed to have agreed` — is widely held unenforceable when the user is not given clear notice and an affirmative manifestation of assent. *Specht v. Netscape* (2d Cir. 2002), *Nguyen v. Barnes & Noble* (9th Cir. 2014), and *Berkson v. Gogo* (E.D.N.Y. 2015) are the modern canon. For consumer-facing contracts, the FTC's *.com Disclosures* guidance treats hidden or passive consent as a deceptive practice.",
      "id": "DARK-007-s1.4-744",
      "recommendation": "Pair the contract with an affirmative manifestation of assent — a click-through checkbox, a typed name, or an e-signature. Confirm reasonable conspicuous notice of the terms prior to the assent step.",
      "rule_id": "DARK-007",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [
        {
          "id": "stat-ftc-deception-statement",
          "license": "Public domain (US government work)",
          "license_url": "https://www.usa.gov/government-works",
          "retrieved_at": "2026-05-11T00:00:00Z",
          "source": "FTC Policy Statement on Deception (1983)",
          "source_url": "https://www.ftc.gov/legal-library/browse/ftc-policy-statement-deception"
        }
      ],
      "title": "Browsewrap / passive-acceptance language"
    },
    {
      "description": "The contract specifies a late-payment rate of 5% per month, which annualizes to approximately 60.0%.",
