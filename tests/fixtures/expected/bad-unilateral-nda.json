  "findings": [
    {
      "description": "Phrase 'liable for all damages without limitation' appears in the document.",
      "document_position": 436,
      "excerpt": {
        "end_offset": 477,
        "section_id": "s1.2",
        "start_offset": 436,
        "text": "n for an indefinite period and shall be liable for all damages without limitation."
      },
      "explanation": "An uncapped or unlimited liability clause exposes a party to an open-ended financial risk. Even mutually agreed-upon caps usually carve out specific categories (fraud, willful misconduct, IP indemnity); a blanket 'no cap' is unusual outside those carve-outs.",
      "id": "RISK-009-s1.2-436",
      "recommendation": "Confirm the scope is intended. If not, add a per-claim and aggregate cap, and enumerate the carve-outs explicitly.",
      "rule_id": "RISK-009",
      "rule_version": "1.0.0",
      "severity": "critical",
      "source_citations": [],
      "title": "Uncapped or unlimited liability"
    },
    {
      "description": "Found 1 placeholder that looks like unfilled template content: \"[insert recipient name]\".",
      "document_position": 128,
      "excerpt": {
        "end_offset": 151,
        "section_id": "s1",
        "start_offset": 128,
        "text": "[insert recipient name]"
      },
      "explanation": "A bracketed placeholder, mustache token, or XXX run that survived into the final document is almost always a drafting accident — the contract is meant to be filled in. A placeholder where a counterparty name belongs makes the agreement legally questionable; a placeholder elsewhere makes the agreement embarrassing.",
      "id": "STRUCT-013-s1-128",
      "recommendation": "Replace every flagged placeholder with the intended content, or remove the bracket if the content is no longer needed.",
      "rule_id": "STRUCT-013",
