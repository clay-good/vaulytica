  "findings": [
    {
      "description": "The contract references data handling (`Customer Data`) but no clause specifies retention duration or deletion obligations.",
      "document_position": 604,
      "excerpt": {
        "end_offset": 617,
        "section_id": "s1.2",
        "start_offset": 604,
        "text": "Customer Data"
      },
      "explanation": "Under GDPR Article 5(1)(e), CCPA, and most modern data-protection regimes, the duration for which data is retained must be defined or tied to a defined purpose. A contract that handles data but says nothing about retention leaves the data subject without a contractual ceiling on how long their information can be held — and leaves the data controller without a clear obligation to delete.",
      "id": "IPDATA-007-s1.2-604",
      "recommendation": "Add an explicit retention clause: how long data is kept (or the trigger that ends retention), what happens at the end of retention (return / deletion / certification of destruction), and the cooperation timeline.",
      "rule_id": "IPDATA-007",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [],
      "title": "Data retention period unspecified"
    },
    {
      "description": "No Effective Date is named, defined, or stated near the top of this Agreement.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no Effective Date reference matched)"
      },
      "explanation": "Most contracts identify a starting point that other date references rely on. Without it, relative terms like 'within 30 days after the Effective Date' have no anchor.",
      "id": "STRUCT-002-s1-0",
      "recommendation": "Add an Effective Date — either in the preamble ('dated as of [date]'), as a defined term, or as an explicit 'Effective Date: [date]' line.",
      "rule_id": "STRUCT-002",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [],
      "title": "No Effective Date found"
    },
    {
      "description": "The contract does not state a path to terminate for material breach.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no for-cause termination)"
      },
      "explanation": "Without a for-cause termination path, parties must rely on common-law material-breach doctrines, which are jurisdiction-dependent.",
      "id": "TERM-002-s1-0",
      "rule_id": "TERM-002",
      "rule_version": "1.0.0",
      "severity": "warning",
      "source_citations": [],
      "title": "No termination-for-cause clause detected"
    },
    {
      "description": "The contract does not state what happens upon termination.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no effect-of-termination clause)"
      },
      "explanation": "An effect-of-termination clause spells out the rights and obligations that survive, the return or destruction of materials, and the wind-down rules.",
      "id": "TERM-005-s1-0",
      "rule_id": "TERM-005",
      "rule_version": "1.2.0",
      "severity": "warning",
      "source_citations": [],
      "title": "No effect-of-termination clause detected"
    },
    {
      "description": "The document does not state where disputes must be brought.",
      "document_position": 0,
      "excerpt": {
        "end_offset": 0,
        "section_id": "s1",
        "start_offset": 0,
        "text": "(no venue clause)"
      },
      "explanation": "Without a venue clause, default venue rules apply (in federal court, 28 U.S.C. § 1391). A clear forum-selection clause avoids ambiguity.",
      "id": "CHOICE-003-s1-0",
      "rule_id": "CHOICE-003",
      "rule_version": "1.0.0",
      "severity": "info",
      "source_citations": [
        {
          "id": "stat-28-usc-1391",
