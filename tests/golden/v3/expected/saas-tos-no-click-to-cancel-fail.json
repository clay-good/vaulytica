ule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-002","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-003","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-004","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-005","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-006","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-007","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-008","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-009","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-010","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-011","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-012","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-013","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-014","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-015","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-016","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-017","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-018","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-019","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-020","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-021","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-022","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-023","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-024","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-025","rule_version":"1.0.0"}],"findings":[{"description":"No clause aligns cancellation difficulty with signup ease (FTC Click-to-Cancel / ROSCA).","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"The FTC's Click-to-Cancel rule and ROSCA both require that cancellation be at least as easy as signup; phone-only cancellation for online-signed subscriptions is non-compliant.","id":"ADDENDA-019-s1-0","recommendation":"Add: 'You may cancel your subscription using the same method you used to subscribe (e.g., online via your account).'","rule_id":"ADDENDA-019","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"addenda-ftc-click-to-cancel-rule","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"FTC Click-to-Cancel Rule","source_url":"https://www.ftc.gov/legal-library/browse/rules/negative-option-rule"}],"title":"FTC Click-to-Cancel alignment missing"},{"description":"Provider may modify these Terms at any time","document_position":2241,"excerpt":{"end_offset":2284,"section_id":"s1","start_offset":2241,"text":"4. Modification of Terms. Provider may modify these Terms at any time by providing Customer with at least thirty (30) days advance written notice via email to the account administrator address on file. If Customer does not agree to the modified Terms, Customer may discontinue use"},"explanation":"A unilateral modification right without a corresponding customer termination right shifts re-pricing and re-negotiation power to the drafter.","id":"DARK-001-s1-2241","rule_id":"DARK-001","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"stat-ftc-deception-statement","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"FTC Policy Statement on Deception (1983)","source_url":"https://www.ftc.gov/legal-library/browse/ftc-policy-statement-deception"}],"title":"Unilateral right to modify terms"},{"description":"modified Terms, Customer may discontinue use of the Service. Continued use of the Service after the effective date of any modification constitutes acceptance","document_position":2451,"excerpt":{"end_offset":2608,"section_id":"s1","start_offset":2451,"text":"ustomer does not agree to the modified Terms, Customer may discontinue use of the Service. Continued use of the Service after the effective date of any modification constitutes acceptance of the modified Terms."},"explanation":"A clause that deems continued use of the service to be acceptance of unilateral amendments has been criticized as illusory: the party 'consenting' has no real notice and no real ability to refuse without disrupting their business. FTC guidance and courts increasingly require affirmative consent for material contract changes.","id":"DARK-009-s1-2451","recommendation":"Require affirmative consent (signed amendment or click-through) for material changes. Continued-use-as-acceptance is acceptable only for non-substantive changes after meaningful written notice and an opt-out window.","rule_id":"DARK-009","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"stat-ftc-deception-statement","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"FTC Policy Statement on Deception (1983)","source_url":"https://www.ftc.gov/legal-library/browse/ftc-policy-statement-deception"}],"title":"Continued-use-as-acceptance amendment clause"},{"description":"The document references fees but no 'Net X' or 'due within' clause was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no payment-term clause)"},"explanation":"Commercial contracts should state when payment is due. 'Net 30' or 'due within X days of invoice' is the typical formulation. Without it, payment timing defaults to the governing-law rule.","id":"FIN-005-s1-0","rule_id":"FIN-005","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No payment-term clause detected"},{"description":"The contract specifies a late-payment rate of 18%, which annualizes to approximately 216.0%.","document_position":4963,"excerpt":{"end_offset":5008,"section_id":"s1","start_offset":4963,"text":"not paid when due will accrue interest at the rate of eighteen percent (18%) per annum (approximately 1.5% per month), which the parties acknowledge does not exceed the maximum rate permitted by N.Y. Gen. Oblig. Law § 5-501, calculated from the due date until paid in fu"},"explanation":"Most US states cap consumer interest in the 18–24%/year range; commercial transactions allow higher contractual rates in many states but several (New York General Obligations Law §5-501, Tennessee, Arkansas pre-Constitutional-Amendment) hold the line tighter. A rate that would be standard in Texas or Delaware may be void in New York or California consumer contexts. Confirm against the controlling jurisdiction.","id":"FIN-009-s1-4963","recommendation":"Confirm the rate is enforceable under the controlling state's usury rules. For consumer-facing contracts, consider capping at 18% annualized. For commercial contracts, document the parties' acknowledgement of the rate.","rule_id":"FIN-009","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"stat-ny-gol-5-501","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"New York General Obligations Law § 5-501 (civil usury)","source_url":"https://www.nysenate.gov/legislation/laws/GOB/5-501"}],"title":"Late-payment rate above 18%/year: ~216.0%"},{"description":"Indemnification language is present (`indemnification obligations`) but no clause caps the aggregate exposure.","document_position":6076,"excerpt":{"end_offset":6103,"section_id":"s1","start_offset":6076,"text":"indemnification obligations"},"explanation":"An indemnity carved out of (or simply not subject to) the liability cap can be the largest single financial risk a contract carries. A third-party IP infringement claim, a data-breach notification cost, or a regulatory fine can dwarf the contract value many times over. Confirm the carve-out is deliberate and proportionate to the indemnifying party's solvency.","id":"RISK-015-s1-6076","recommendation":"Either subject indemnification to a per-claim and aggregate cap, or confirm the carve-out is a deliberate trade for higher pricing / different insurance.","rule_id":"RISK-015","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Indemnification without aggregate cap"},{"description":"Used but not defined: Customer Data, Order Form.","document_position":2804,"excerpt":{"end_offset":2817,"section_id":"s1","start_offset":2804,"text":"Customer Data"},"explanation":"Title-Case phrases in a contract usually signal a defined term. When they aren't defined, readers must guess at the intended meaning. Either define them or use lowercase if the term is intended in its ordinary sense.","id":"STRUCT-006-s1-2804","recommendation":"Add a definition for each genuinely defined term, or change the casing if the phrase is being used in its ordinary sense.","rule_id":"STRUCT-006","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Undefined Title-Case terms: 2"},{"description":"The following references do not resolve to any section: Section 1, Section 9, Section 5.","document_position":5691,"excerpt":{"end_offset":5700,"section_id":"s1","start_offset":5691,"text":"Section 1"},"explanation":"A broken cross-reference can mean the referenced section was renumbered or deleted, or that a section reference was made up. Either way the reader has no way to follow the citation.","id":"STRUCT-007-s1-5691","recommendation":"Update each broken reference to point to the correct section, or delete it if it is no longer applicable.","rule_id":"STRUCT-007","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Unresolved cross-references: 3"},{"description":"The contract contains automatic-renewal language.","document_position":1507,"excerpt":{"end_offset":1517,"section_id":"s1","start_offset":1507,"text":"3. Auto-Renewal. Each subscription term will automatically renew for successive terms of equal length. To request non-renewal, Customer must call Provider's billing department at +1 (302) 555-0188 during"},"explanation":"Auto-renewal commits the customer to another term unless they actively opt out. The notice window is the critical detail; verify it is reasonable and well-located.","id":"TEMP-004-s1-1507","rule_id":"TEMP-004","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"stat-16-cfr-425","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"16 C.F.R. Part 425 (FTC Negative Option Rule)","source_url":"https://www.ecfr.gov/current/title-16/chapter-I/subchapter-D/part-425"}],"title":"Auto-renewal clause present"},{"description":"The contract does not state what happens upon termination.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no effect-of-termination clause)"},"explanation":"An effect-of-termination clause spells out the rights and obligations that survive, the return or destruction of materials, and the wind-down rules.","id":"TERM-005-s1-0","rule_id":"TERM-005","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No effect-of-termination clause detected"},{"description":"The document does not state where disputes must be brought.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no venue clause)"},"explanation":"Without a venue clause, default venue rules apply (in federal court, 28 U.S.C. § 1391). A clear forum-selection clause avoids ambiguity.","id":"CHOICE-003-s1-0","rule_id":"CHOICE-003","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"stat-28-usc-1391","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"28 U.S.C. § 1391 (venue generally)","source_url":"https://www.law.cornell.edu/uscode/text/28/1391"}],"title":"No venue / forum clause detected"},{"description":"The contract references data but does not separately allocate data ownership.","document_position":2804,"excerpt":{"end_offset":2817,"section_id":"s1","start_offset":2804,"text":"5. Data Ownership. Customer retains all right, title, and interest in and to the data, content, and information that Customer uploads to or processes through the Service (\"Customer Data\"). Provider acquires no ownership interest in Customer"},"explanation":"IP and data ownership are different. For SaaS, the customer typically owns its data; the vendor typically owns usage analytics. Address each explicitly.","id":"IPDATA-004-s1-2804","rule_id":"IPDATA-004","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Data ownership not separately addressed"},{"description":"Customer shall use the Service only for lawful business purposes and shall not: (a) use the Service to transmit spam, ma | Written requests, email requests, and requests submitted through the account portal will not be accepted for cancellatio | Cancellation requests received fewer than sixty (60) days before the renewal date will not take effect until the followi | Provider shall make the Customer Data available for export during this thirty (30)-day window and shall not delete or re","document_position":633,"excerpt":{"end_offset":1013,"section_id":"s1","start_offset":633,"text":"Customer shall use the Service only for lawful business purposes and shall not: (a) use the Service to transmit spam, malware, or unlawful content; (b) attempt to gain unauthorized access to the Service or Provider's systems; (c) use the Service to violate the rights of any third party; or (d) resell or sublicense access to the Service without Provider's prior written consent."},"explanation":"Negative covenants restrict what a party may do. Surfacing them collectively makes it easier to check they are intended and consistent with the overall deal.","id":"OBLI-005-s1-633","rule_id":"OBLI-005","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Negative covenants: 4"},{"description":"Indemnity clause appears to be missing: notice, defense control, settlement consent.","document_position":6076,"excerpt":{"end_offset":6084,"section_id":"s1","start_offset":6076,"text":"11. Survival. The following provisions survive expiration or termination of these Terms for any reason: payment obligations (Section 9), intellectual property rights (Section 5), indemnification obligations, confidentiality obligations, limitation of liability, and this survival "},"explanation":"A complete indemnity clause specifies (a) the timeline and form for notice of a claim, (b) which party controls defense, and (c) whether settlement requires consent.","id":"RISK-011-s1-6076","rule_id":"RISK-011","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Indemnity procedural elements missing: notice, defense control, settlement consent"},{"description":"Vaulytica did not find a Definitions section or any inline-defined terms.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no definitions located)"},"explanation":"Most non-trivial contracts capitalize defined terms and either set them out in a Definitions section or define them inline (\"X\" means …). Their absence is not by itself a problem, but downstream rules that check for use of specific defined terms will be skipped.","id":"STRUCT-004-s1-0","rule_id":"STRUCT-004","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"No defined terms detected"},{"description":"Provisions are stated to survive termination.","document_position":5936,"excerpt":{"end_offset":5969,"section_id":"s1","start_offset":5936,"text":"11. Survival. The following provisions survive expiration or termination of these Terms for any reason: payment obligations (Section 9), intellectual property rights (Section 5), indemnification obligations, confidentiality obligations, lim"},"explanation":"A survival clause names the obligations that outlast termination — typically confidentiality, indemnity, payment obligations accrued before termination, and choice of law.","id":"TEMP-006-s1-5936","rule_id":"TEMP-006","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Survival clause present"},{"description":"Survival clause does not appear to include: governing law.","document_position":5936,"excerpt":{"end_offset":5969,"section_id":"s1","start_offset":5936,"text":"11. Survival. The following provisions survive expiration or termination of these Terms for any reason: payment obligations (Section 9), intellectual property rights (Section 5), indemnification obligations, confidentiality obligations, lim"},"explanation":"Typical surviving obligations include confidentiality, indemnity, accrued payment obligations, and governing law. Missing any of these is common and worth confirming.","id":"TEMP-007-s1-5936","rule_id":"TEMP-007","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Survival list may be missing categories: governing law"}],"playbook_id":"saas-tos","playbook_match_confidence":1,"playbook_match_reasoning":"forced via sidecar to saas-tos","result_hash":"4e23705b2e97d53bbd02e86bcc02bb3cc0a707e7f56f59efb61c1c58d4f8b5d5","source_file":{"name":"saas-tos-no-click-to-cancel-fail.txt","sha256":"9d088bdc16cb648ef2266bc04b99824b37a5401d1b3934d27f4aeb37afe07863","size_bytes":1},"version":"9.41.0"}