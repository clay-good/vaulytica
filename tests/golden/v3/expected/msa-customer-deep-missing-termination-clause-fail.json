ersion":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-025","rule_version":"1.0.0"}],"findings":[{"description":"No aggregate cap on liability was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Absent a cap, liability is unbounded — an unusual posture for a commercial MSA.","id":"MSA-006-s1-0","recommendation":"Add an aggregate cap (commonly 12 months' fees) with explicit carve-outs.","rule_id":"MSA-006","rule_version":"1.0.0","severity":"critical","source_citations":[{"id":"msa-deep-commercial-drafting-baseline-aggregate-cap","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Commercial drafting baseline — aggregate cap","source_url":"https://www.law.cornell.edu/ucc"}],"title":"Aggregate liability cap missing"},{"description":"Worker / party is identified as California-based but the contract selects Delaware law.","document_position":8428,"excerpt":{"end_offset":8506,"section_id":"s1","start_offset":8428,"text":"Delaware"},"explanation":"Cal. Lab. Code § 925 voids out-of-state choice-of-law clauses in employment contracts entered into, modified, or extended after Jan. 1, 2017 — unless the employee was individually represented by counsel in negotiating that specific clause. Cal. Bus. & Prof. Code § 16600.5 (2024) extends similar reasoning to non-competes: they are unenforceable regardless of where signed if the worker is in California, and create a private right of action with attorneys' fees. This pattern is commonly used to evade California's strict non-compete prohibitions; courts (e.g., *Lyon v. Neustar*) routinely refuse to enforce it.","id":"CHOICE-011-s1-8428","recommendation":"Either change governing law to California, or include a §925 counsel-representation acknowledgment. Note that §16600.5 may render any non-compete unenforceable even with §925-compliant choice-of-law language.","rule_id":"CHOICE-011","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"stat-ca-bp-16600","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"California Business and Professions Code § 16600","source_url":"https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?lawCode=BPC&sectionNum=16600."}],"title":"Out-of-state choice-of-law on California-based party"},{"description":"No third-party IP infringement indemnification clause was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"A vendor-supplied product that infringes a third party's IP exposes the customer to suit. The standard allocation is that the vendor indemnifies for IP claims.","id":"MSA-001-s1-0","recommendation":"Add a third-party IP infringement indemnity (defense, settlement, damages) with the usual customer-cooperation conditions.","rule_id":"MSA-001","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"msa-deep-commercial-drafting-baseline-indemnification-scope","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Commercial drafting baseline — indemnification scope","source_url":"https://www.law.cornell.edu/ucc"}],"title":"IP infringement indemnity missing"},{"description":"No compliance-with-laws or non-infringement warranty was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Customers expect a vendor to warrant lawful operation and non-infringement.","id":"MSA-014-s1-0","recommendation":"Add: services and deliverables (a) comply with applicable laws and (b) do not infringe any third-party IP rights.","rule_id":"MSA-014","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"msa-deep-commercial-drafting-baseline-compliance-non-infringement","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Commercial drafting baseline — compliance/non-infringement","source_url":"https://www.law.cornell.edu/ucc"}],"title":"Compliance-with-laws / non-infringement warranty missing"},{"description":"No SLA / service level agreement / uptime commitment was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"An MSA for hosted services without an SLA leaves availability promises unenforceable.","id":"MSA-016-s1-0","recommendation":"Reference an SLA (attached or linked) with uptime, support response, and remedy schedules.","rule_id":"MSA-016","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"msa-deep-commercial-drafting-baseline-sla-reference","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Commercial drafting baseline — SLA reference","source_url":"https://www.law.cornell.edu/ucc"}],"title":"SLA reference missing"},{"description":"No termination-for-material-breach clause with a cure window was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Without an explicit material-breach termination right the customer is forced into a common-law theory.","id":"MSA-018-s1-0","recommendation":"Add: either party may terminate on N (e.g., 30) days' written notice of an uncured material breach.","rule_id":"MSA-018","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"msa-deep-commercial-drafting-baseline-material-breach-termination","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Commercial drafting baseline — material-breach termination","source_url":"https://www.law.cornell.edu/ucc"}],"title":"Termination for material breach missing"},{"description":"Used but not defined: Customer Data, Two Million Dollars, Vendor Background.","document_position":7414,"excerpt":{"end_offset":7427,"section_id":"s1","start_offset":7414,"text":"Customer Data"},"explanation":"Title-Case phrases in a contract usually signal a defined term. When they aren't defined, readers must guess at the intended meaning. Either define them or use lowercase if the term is intended in its ordinary sense.","id":"STRUCT-006-s1-7414","recommendation":"Add a definition for each genuinely defined term, or change the casing if the phrase is being used in its ordinary sense.","rule_id":"STRUCT-006","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Undefined Title-Case terms: 3"},{"description":"The following references do not resolve to any section: Section 8(a), Section 8(a), Section 7, Section 6.","document_position":4770,"excerpt":{"end_offset":4782,"section_id":"s1","start_offset":4770,"text":"Section 8(a)"},"explanation":"A broken cross-reference can mean the referenced section was renumbered or deleted, or that a section reference was made up. Either way the reader has no way to follow the citation.","id":"STRUCT-007-s1-4770","recommendation":"Update each broken reference to point to the correct section, or delete it if it is no longer applicable.","rule_id":"STRUCT-007","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Unresolved cross-references: 4"},{"description":"The survival clause exists but does not name: IP ownership / assignment, indemnification.","document_position":2969,"excerpt":{"end_offset":3637,"section_id":"s1","start_offset":2969,"text":"6. Confidentiality. Each party (as \"Receiving Party\") shall hold in strict confidence all non-public information of the other party (as \"Disclosing Party\") designated as confidential or that reasonably should be understood to be confidential. Each party shall use such information"},"explanation":"Survival language is what keeps sticky obligations alive after a contract terminates. A survival clause that doesn't expressly enumerate the present-in-document confidentiality / IP / indemnity obligations creates ambiguity at the moment those obligations matter most — post-termination, when the contract has already ended.","id":"TEMP-012-s1-2969","recommendation":"Add explicit named references to the missing obligation(s): IP ownership / assignment, indemnification. Standard drafting names every sticky section by number or category in the survival clause.","rule_id":"TEMP-012","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Survival clause does not name 2 sticky obligations"},{"description":"Customer may terminate this Agreement for convenience upon thirty (30) days prior written notice to Vendor. In the event of termination for convenience","document_position":6744,"excerpt":{"end_offset":6895,"section_id":"s1","start_offset":6744,"text":"10. Termination. Customer may terminate this Agreement for convenience upon thirty (30) days prior written notice to Vendor. In the event of termination for convenience, Customer shall pay Vendor for all services satisfactorily performed th"},"explanation":"An asymmetric termination-for-convenience right is sometimes intentional (e.g., paid-up vendors), but the asymmetry should be deliberate.","id":"TERM-003-s1-6744","rule_id":"TERM-003","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Only one party may terminate for convenience"},{"description":"The contract does not state what happens upon termination.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no effect-of-termination clause)"},"explanation":"An effect-of-termination clause spells out the rights and obligations that survive, the return or destruction of materials, and the wind-down rules.","id":"TERM-005-s1-0","rule_id":"TERM-005","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No effect-of-termination clause detected"},{"description":"The document does not state where disputes must be brought.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no venue clause)"},"explanation":"Without a venue clause, default venue rules apply (in federal court, 28 U.S.C. § 1391). A clear forum-selection clause avoids ambiguity.","id":"CHOICE-003-s1-0","rule_id":"CHOICE-003","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"stat-28-usc-1391","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"28 U.S.C. § 1391 (venue generally)","source_url":"https://www.law.cornell.edu/uscode/text/28/1391"}],"title":"No venue / forum clause detected"},{"description":"The contract references data but does not separately allocate data ownership.","document_position":7414,"excerpt":{"end_offset":7427,"section_id":"s1","start_offset":7414,"text":"11. Data Portability and Return on Termination. Upon expiration or termination of this Agreement for any reason, Vendor shall: (a) promptly provide Customer with a complete, machine-readable export of all Customer Data in a standard, non-pr"},"explanation":"IP and data ownership are different. For SaaS, the customer typically owns its data; the vendor typically owns usage analytics. Address each explicitly.","id":"IPDATA-004-s1-7414","rule_id":"IPDATA-004","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Data ownership not separately addressed"},{"description":"No transition / wind-down / hosted-service continuation period was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Without a wind-down, the customer can be cut off mid-migration.","id":"MSA-020-s1-0","recommendation":"Add: vendor will continue providing the service for up to N (e.g., 90) days post-termination at then-current rates to facilitate transition.","rule_id":"MSA-020","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"msa-deep-commercial-drafting-baseline-transition-assistance","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Commercial drafting baseline — transition assistance","source_url":"https://www.law.cornell.edu/ucc"}],"title":"Wind-down / transition assistance missing"},{"description":"No bilateral force-majeure language was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"A one-sided force-majeure clause (vendor-only) is commercially abnormal; payment obligations are conventionally excluded.","id":"MSA-022-s1-0","recommendation":"Add: 'neither party shall be liable for delay or failure due to force majeure', with a payment-obligation carve-out.","rule_id":"MSA-022","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"msa-deep-commercial-drafting-baseline-balanced-force-majeure","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Commercial drafting baseline — balanced force majeure","source_url":"https://www.law.cornell.edu/ucc"}],"title":"Balanced force majeure missing"},{"description":"No amendment-in-writing or no-waiver boilerplate found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Without these, oral modifications and unintentional waivers become litigation risks.","id":"MSA-025-s1-0","recommendation":"Add: 'no amendment is effective unless in writing signed by both parties' and 'no failure to enforce shall be deemed a waiver.'","rule_id":"MSA-025","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"msa-deep-commercial-drafting-baseline-amendment-waiver","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Commercial drafting baseline — amendment / waiver","source_url":"https://www.law.cornell.edu/ucc"}],"title":"Amendment-in-writing / no-waiver missing"},{"description":"No clause was found addressing AI / generative AI usage by the vendor in service delivery.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Increasingly the contract should disclose AI use, training data, and IP ownership of outputs (see the §49 AI Addendum playbook for the deep check).","id":"MSA-028-s1-0","recommendation":"Add a clause disclosing whether AI is used, naming material AI subprocessors, and addressing IP in outputs.","rule_id":"MSA-028","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"msa-deep-nist-ai-rmf-transparency-baseline","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"NIST AI RMF — transparency baseline","source_url":"https://www.nist.gov/itl/ai-risk-management-framework"}],"title":"AI usage clause missing"},{"description":"Exclusive / limited remedy language is present but no UCC § 2-719(2) fail-of-essential-purpose escape was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"UCC § 2-719(2) preserves alternative remedies when a limited remedy fails of its essential purpose — anchoring this protects the customer from a remedy gap.","id":"MSA-030-s1-0","recommendation":"Add: 'if the limited remedy is found to fail of its essential purpose, the customer's other remedies under this Agreement and applicable law remain available.'","rule_id":"MSA-030","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"msa-deep-u-c-c-2-719-2-","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"U.C.C. § 2-719(2)","source_url":"https://www.law.cornell.edu/ucc/2/2-719"}],"title":"UCC § 2-719 limited-remedy escape missing"},{"description":"Each party's aggregate liability to the other party for all claims arising out of or related to this Agreement shall not | The aggregate liability cap in Section 8(a) shall not apply to: (i) Vendor's indemnification obligations under Section 7 | This mutual exclusion of consequential damages shall not apply to breaches of confidentiality obligations or indemnifica","document_position":4840,"excerpt":{"end_offset":5167,"section_id":"s1","start_offset":4840,"text":"Each party's aggregate liability to the other party for all claims arising out of or related to this Agreement shall not exceed the greater of: (i) One Million Dollars ($1,000,000); or (ii) the total fees paid or payable by Customer to Vendor in the twelve (12) months immediately preceding the claim giving rise to liability."},"explanation":"Negative covenants restrict what a party may do. Surfacing them collectively makes it easier to check they are intended and consistent with the overall deal.","id":"OBLI-005-s1-4840","rule_id":"OBLI-005","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Negative covenants: 3"},{"description":"incidental, special, exemplary, or consequential damages","document_position":5599,"excerpt":{"end_offset":5655,"section_id":"s1","start_offset":5599,"text":"8. Limitation of Liability. (a) Aggregate Liability Cap. Each party's aggregate liability to the other party for all claims arising out of or related to this Agreement shall not exceed the greater of: (i) One Million Dollars ($1,000,000); o"},"explanation":"A waiver of consequential, special, incidental, and punitive damages is standard in commercial contracts. The waiver should be mutual unless deliberately asymmetric.","id":"RISK-007-s1-5599","rule_id":"RISK-007","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Consequential damages waiver present"},{"description":"commercial general liability insurance with limits of at least Two Million Dollars ($2,000,000","document_position":6174,"excerpt":{"end_offset":6268,"section_id":"s1","start_offset":6174,"text":"9. Vendor Insurance. During the term of this Agreement and for two (2) years thereafter, Vendor shall maintain, at its own expense: (a) commercial general liability insurance with limits of at least Two Million Dollars ($2,000,000) per occurrence and Five Million Dollars ($5,000,000) in the aggregate; (b) professional "},"explanation":"Insurance levels should match the deal size and risk. Common minimums are $1M per occurrence CGL and $2M E&O for services contracts.","id":"RISK-010-s1-6174","rule_id":"RISK-010","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Insurance requirements stated"},{"description":"Indemnity clause appears to be missing: notice, settlement consent.","document_position":3648,"excerpt":{"end_offset":3656,"section_id":"s1","start_offset":3648,"text":"7. Vendor Indemnification. Vendor shall indemnify, defend, and hold harmless Customer and its officers, directors, employees, and agents (\"Customer Indemnitees\") from and against any third-party claim, suit, or proceeding arising out of or relating to: (a) any allegation that the"},"explanation":"A complete indemnity clause specifies (a) the timeline and form for notice of a claim, (b) which party controls defense, and (c) whether settlement requires consent.","id":"RISK-011-s1-3648","rule_id":"RISK-011","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Indemnity procedural elements missing: notice, settlement consent"},{"description":"confidentiality obligations no less protective than this Agreement. These obligations survive termination of this Agreement for three (3) year","document_position":3427,"excerpt":{"end_offset":3569,"section_id":"s1","start_offset":3427,"text":"6. Confidentiality. Each party (as \"Receiving Party\") shall hold in strict confidence all non-public information of the other party (as \"Disclosing Party\") designated as confidential or that reasonably should be understood to be confidentia"},"explanation":"Typical post-termination confidentiality terms run 3–5 years for general information, with a perpetual duty for trade secrets. Verify the term matches the sensitivity of the information.","id":"RISK-014-s1-3427","rule_id":"RISK-014","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Confidentiality term length stated"},{"description":"Vaulytica did not find a Definitions section or any inline-defined terms.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no definitions located)"},"explanation":"Most non-trivial contracts capitalize defined terms and either set them out in a Definitions section or define them inline (\"X\" means …). Their absence is not by itself a problem, but downstream rules that check for use of specific defined terms will be skipped.","id":"STRUCT-004-s1-0","rule_id":"STRUCT-004","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"No defined terms detected"},{"description":"Provisions are stated to survive termination.","document_position":3513,"excerpt":{"end_offset":3532,"section_id":"s1","start_offset":3513,"text":"6. Confidentiality. Each party (as \"Receiving Party\") shall hold in strict confidence all non-public information of the other party (as \"Disclosing Party\") designated as confidential or that reasonably should be understood to be confidentia"},"explanation":"A survival clause names the obligations that outlast termination — typically confidentiality, indemnity, payment obligations accrued before termination, and choice of law.","id":"TEMP-006-s1-3513","rule_id":"TEMP-006","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Survival clause present"},{"description":"Survival clause does not appear to include: indemnity, payment, governing law.","document_position":3513,"excerpt":{"end_offset":3532,"section_id":"s1","start_offset":3513,"text":"6. Confidentiality. Each party (as \"Receiving Party\") shall hold in strict confidence all non-public information of the other party (as \"Disclosing Party\") designated as confidential or that reasonably should be understood to be confidentia"},"explanation":"Typical surviving obligations include confidentiality, indemnity, accrued payment obligations, and governing law. Missing any of these is common and worth confirming.","id":"TEMP-007-s1-3513","rule_id":"TEMP-007","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Survival list may be missing categories: indemnity, payment, governing law"}],"playbook_id":"msa-customer-deep","playbook_match_confidence":1,"playbook_match_reasoning":"forced via sidecar to msa-customer-deep","result_hash":"f69b95dfa3dce3cf4d556bfe37a2d8aea881561c1a40e313361166ddbdc4279b","source_file":{"name":"msa-customer-deep-missing-termination-clause-fail.txt","sha256":"98cd2e80c64aaebfbbc803a88a0075239fc98c8fccf6e9cb9b4c11afc3be0055","size_bytes":1},"version":"0.1.0"}