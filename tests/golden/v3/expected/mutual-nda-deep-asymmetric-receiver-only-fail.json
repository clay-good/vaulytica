d_ms":0,"fired":false,"rule_id":"USDPA-022","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-023","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-024","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-025","rule_version":"1.0.0"}],"findings":[{"description":"No clause was found defining the duration of confidentiality obligations.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Industry consensus and UTSA practice require an explicit confidentiality term. Without one, the duration is ambiguous and may not be enforceable in some jurisdictions.","id":"NDA-D-003-s1-0","recommendation":"Add a clause stating either a definite term (e.g., 5 years from disclosure) or, preferably, a definite term for confidential information plus a perpetual term for trade secrets.","rule_id":"NDA-D-003","rule_version":"1.0.0","severity":"critical","source_citations":[{"id":"utsa-1985","license":"Public uniform-law text","license_url":"https://www.uniformlaws.org/HigherLogic/System/DownloadDocumentFile.ashx?DocumentFileKey=e19b2528-e0b1-0054-23c4-8069701a4b62","retrieved_at":"2026-05-12T00:00:00Z","source":"Uniform Trade Secrets Act (UTSA) (1985 amended)","source_url":"https://www.uniformlaws.org/committees/community-home?CommunityKey=3a2538fb-e030-4e2d-a9e2-90373dc05792"}],"title":"Confidentiality term clause missing"},{"description":"Confidential-Information definition lacks an exclusion for information previously known to the receiving party.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Without a 'previously known' carve-out, the receiver risks breaching the NDA by using information they already possessed.","id":"NDA-D-007-s1-0","recommendation":"Add: 'Confidential Information does not include information already known to Receiving Party prior to disclosure, as evidenced by its written records.'","rule_id":"NDA-D-007","rule_version":"1.0.0","severity":"critical","source_citations":[{"id":"nda-consensus-drafting","license":"Common Paper Standard NDA, CC BY 4.0","license_url":"https://creativecommons.org/licenses/by/4.0/","retrieved_at":"2026-05-12T00:00:00Z","source":"Consensus NDA drafting practice (Common Paper, ACC, ABA practice notes)","source_url":"https://commonpaper.com/standards/mutual-nda/"}],"title":"'Already known' exclusion missing"},{"description":"No clause was found acknowledging irreparable harm or entitlement to injunctive relief.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Without an irreparable-harm acknowledgment, a court may require the discloser to prove inadequate-remedy-at-law from scratch, slowing emergency relief in a leak scenario.","id":"NDA-D-015-s1-0","recommendation":"Add: 'The parties agree that monetary damages would be an inadequate remedy for any breach of this Agreement and that the non-breaching party shall be entitled to seek injunctive or other equitable relief, in addition to any other available remedies.'","rule_id":"NDA-D-015","rule_version":"1.0.0","severity":"critical","source_citations":[{"id":"nda-consensus-drafting","license":"Common Paper Standard NDA, CC BY 4.0","license_url":"https://creativecommons.org/licenses/by/4.0/","retrieved_at":"2026-05-12T00:00:00Z","source":"Consensus NDA drafting practice (Common Paper, ACC, ABA practice notes)","source_url":"https://commonpaper.com/standards/mutual-nda/"}],"title":"Injunctive-relief clause missing"},{"description":"No clause was found stating that disclosure does not grant a license or ownership interest.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Without a no-license clause, an aggressive receiver could argue an implied license arose from disclosure. The fix is a one-line denial.","id":"NDA-D-021-s1-0","recommendation":"Add: 'No license or other right is granted to Receiving Party in or to the Confidential Information except as expressly set forth in this Agreement.'","rule_id":"NDA-D-021","rule_version":"1.0.0","severity":"critical","source_citations":[{"id":"nda-consensus-drafting","license":"Common Paper Standard NDA, CC BY 4.0","license_url":"https://creativecommons.org/licenses/by/4.0/","retrieved_at":"2026-05-12T00:00:00Z","source":"Consensus NDA drafting practice (Common Paper, ACC, ABA practice notes)","source_url":"https://commonpaper.com/standards/mutual-nda/"}],"title":"No-license clause missing"},{"description":"The contract does not allocate ownership of intellectual property.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no IP-ownership clause)"},"explanation":"Without an IP-ownership clause, default copyright and patent rules apply: under 17 U.S.C. § 201, copyright vests in the author/employee unless work-for-hire or assignment applies.","id":"IPDATA-001-s1-0","rule_id":"IPDATA-001","rule_version":"1.2.0","severity":"warning","source_citations":[{"id":"stat-17-usc-101","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"17 U.S.C. § 101 — Definitions (work made for hire)","source_url":"https://www.law.cornell.edu/uscode/text/17/101"},{"id":"stat-17-usc-201","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"17 U.S.C. § 201","source_url":"https://www.law.cornell.edu/uscode/text/17/201"}],"title":"No IP-ownership clause detected"},{"description":"Return-or-destruction language was detected but does not require written certification of destruction.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Without an attestation requirement, the discloser has no proof that destruction actually occurred — a real-world enforcement gap.","id":"NDA-D-014-s1-0","recommendation":"Add: 'Receiving Party shall provide a written certification, signed by an officer, attesting to compliance with this Section within thirty (30) days.'","rule_id":"NDA-D-014","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"nda-consensus-drafting","license":"Common Paper Standard NDA, CC BY 4.0","license_url":"https://creativecommons.org/licenses/by/4.0/","retrieved_at":"2026-05-12T00:00:00Z","source":"Consensus NDA drafting practice (Common Paper, ACC, ABA practice notes)","source_url":"https://commonpaper.com/standards/mutual-nda/"}],"title":"Return-or-destruction attestation missing"},{"description":"Injunctive-relief clause does not include a waiver of bond.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Many courts require a movant to post a bond as a condition of preliminary injunctive relief. A contractual waiver smooths the emergency-motion path.","id":"NDA-D-016-s1-0","recommendation":"Add: 'The party seeking injunctive relief shall be entitled to such relief without the need to post a bond or other security.'","rule_id":"NDA-D-016","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"nda-consensus-drafting","license":"Common Paper Standard NDA, CC BY 4.0","license_url":"https://creativecommons.org/licenses/by/4.0/","retrieved_at":"2026-05-12T00:00:00Z","source":"Consensus NDA drafting practice (Common Paper, ACC, ABA practice notes)","source_url":"https://commonpaper.com/standards/mutual-nda/"}],"title":"Waiver-of-bond language missing"},{"description":"Detected language imposing an obligation solely on the 'Receiving Party' (or one named party) in what should be a mutual agreement.","document_position":2569,"excerpt":{"end_offset":2806,"section_id":"s1","start_offset":2569,"text":"5. Receiving Party Representations. The Receiving Party represents and warrants that it has the authority to enter into this Agreement and shall comply with all applicable laws in connection with its handling of Confidential Information."},"explanation":"Mutual NDAs are typically drafted with each party as both Disclosing and Receiving Party. Asymmetric drafting suggests either (a) the wrong template was used, or (b) one party is silently advantaged.","id":"NDA-D-024-s1-2569","recommendation":"Rewrite the obligation as bilateral: 'Each party shall ...' rather than 'Receiving Party shall ...'.","rule_id":"NDA-D-024","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"nda-consensus-drafting","license":"Common Paper Standard NDA, CC BY 4.0","license_url":"https://creativecommons.org/licenses/by/4.0/","retrieved_at":"2026-05-12T00:00:00Z","source":"Consensus NDA drafting practice (Common Paper, ACC, ABA practice notes)","source_url":"https://commonpaper.com/standards/mutual-nda/"}],"title":"Mutual NDA contains a receiver-only / one-sided obligation"},{"description":"Vaulytica did not find a limitation-of-liability clause.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no LoL clause)"},"explanation":"Without a limitation-of-liability clause, exposure is bounded only by what the parties can prove in damages. Most commercial contracts cap liability.","id":"RISK-005-s1-0","rule_id":"RISK-005","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No limitation-of-liability clause detected"},{"description":"Indemnification language is present (`shall indemnify`) but no clause caps the aggregate exposure.","document_position":2863,"excerpt":{"end_offset":2878,"section_id":"s1","start_offset":2863,"text":"shall indemnify"},"explanation":"An indemnity carved out of (or simply not subject to) the liability cap can be the largest single financial risk a contract carries. A third-party IP infringement claim, a data-breach notification cost, or a regulatory fine can dwarf the contract value many times over. Confirm the carve-out is deliberate and proportionate to the indemnifying party's solvency.","id":"RISK-015-s1-2863","recommendation":"Either subject indemnification to a per-claim and aggregate cap, or confirm the carve-out is a deliberate trade for higher pricing / different insurance.","rule_id":"RISK-015","rule_version":"1.2.0","severity":"warning","source_citations":[],"title":"Indemnification without aggregate cap"},{"description":"The survival clause exists but does not name: indemnification.","document_position":3044,"excerpt":{"end_offset":3505,"section_id":"s1","start_offset":3044,"text":"7. Term. This Agreement shall commence on the Effective Date and continue for a period of three (3) years, unless earlier terminated by either Party upon thirty (30) days written notice. Notwithstanding the foregoing, the obligations of confidentiality with respect to information"},"explanation":"Survival language is what keeps sticky obligations alive after a contract terminates. A survival clause that doesn't expressly enumerate the present-in-document confidentiality / IP / indemnity obligations creates ambiguity at the moment those obligations matter most — post-termination, when the contract has already ended.","id":"TEMP-012-s1-3044","recommendation":"Add explicit named references to the missing obligation(s): indemnification. Standard drafting names every sticky section by number or category in the survival clause.","rule_id":"TEMP-012","rule_version":"1.1.0","severity":"warning","source_citations":[],"title":"Survival clause does not name 1 sticky obligation"},{"description":"The contract does not state a path to terminate for material breach.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no for-cause termination)"},"explanation":"Without a for-cause termination path, parties must rely on common-law material-breach doctrines, which are jurisdiction-dependent.","id":"TERM-002-s1-0","rule_id":"TERM-002","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No termination-for-cause clause detected"},{"description":"No clause was found stating that the NDA does not establish precedent for future agreements.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"A no-precedent clause prevents the receiver from arguing that prior NDAs control subsequent commercial-deal drafting. Optional but common.","id":"NDA-D-019-s1-0","recommendation":"Add: 'This Agreement is not intended to create, and shall not be construed as creating, a precedent for any future agreement between the parties.'","rule_id":"NDA-D-019","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"nda-consensus-drafting","license":"Common Paper Standard NDA, CC BY 4.0","license_url":"https://creativecommons.org/licenses/by/4.0/","retrieved_at":"2026-05-12T00:00:00Z","source":"Consensus NDA drafting practice (Common Paper, ACC, ABA practice notes)","source_url":"https://commonpaper.com/standards/mutual-nda/"}],"title":"No-precedent / no-MFN clause missing"},{"description":"The Receiving Party shall not disclose Confidential Information to any third party without the prior written consent of  | § 1833(b), an employee shall not be held criminally or civilly liable under any Federal or State trade secret law for th","document_position":1766,"excerpt":{"end_offset":1908,"section_id":"s1","start_offset":1766,"text":"The Receiving Party shall not disclose Confidential Information to any third party without the prior written consent of the Disclosing Party."},"explanation":"Negative covenants restrict what a party may do. Surfacing them collectively makes it easier to check they are intended and consistent with the overall deal.","id":"OBLI-005-s1-1766","rule_id":"OBLI-005","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Negative covenants: 2"},{"description":"Indemnity clause appears to be missing: defense control, settlement consent.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"6. Receiving Party Indemnification. The Receiving Party shall indemnify, defend, and hold harmless the Disclosing Party from and against any losses, damages, and expenses arising out of a breach of this Agreement by the Receiving Party."},"explanation":"A complete indemnity clause specifies (a) the timeline and form for notice of a claim, (b) which party controls defense, and (c) whether settlement requires consent.","id":"RISK-011-s1-0","rule_id":"RISK-011","rule_version":"1.3.0","severity":"info","source_citations":[],"title":"Indemnity procedural elements missing: defense control, settlement consent"},{"description":"Confidential Information","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"Confidential Information"},"explanation":"Defined terms should be capitalized identically wherever they appear. A lowercase use of a defined term reads as ordinary usage and can change the meaning.","id":"STRUCT-009-s1-0","rule_id":"STRUCT-009","rule_version":"1.4.0","severity":"info","source_citations":[],"title":"Inconsistent capitalization for 1 defined term"},{"description":"1 reference uses the lowercase form of a defined term — likely a drafting slip. Affected terms: \"Confidential Information\".","document_position":361,"excerpt":{"end_offset":385,"section_id":"s1","start_offset":361,"text":"Confidential Information"},"explanation":"A defined term carries its contractual meaning only when it is referenced with the same casing as its definition. A lowercase occurrence either creates a genuine ambiguity (the reader cannot tell if the defined meaning was intended) or signals a missed capitalization. Courts in commercial drafting jurisdictions sometimes read lowercase variants as the plain-English meaning rather than the defined meaning.","id":"STRUCT-014-s1-361","recommendation":"Recapitalize each lowercase occurrence to match the defined casing, or remove the term entirely if the unaltered plain-English meaning was intended.","rule_id":"STRUCT-014","rule_version":"1.2.0","severity":"info","source_citations":[],"title":"Defined terms used in lowercase: 1"},{"description":"Provisions are stated to survive termination.","document_position":3384,"excerpt":{"end_offset":3403,"section_id":"s1","start_offset":3384,"text":"7. Term. This Agreement shall commence on the Effective Date and continue for a period of three (3) years, unless earlier terminated by either Party upon thirty (30) days written notice. Notwithstanding the foregoing, the obligations of con"},"explanation":"A survival clause names the obligations that outlast termination — typically confidentiality, indemnity, payment obligations accrued before termination, and choice of law.","id":"TEMP-006-s1-3384","rule_id":"TEMP-006","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Survival clause present"},{"description":"Survival clause does not appear to include: indemnity, payment, governing law.","document_position":3384,"excerpt":{"end_offset":3403,"section_id":"s1","start_offset":3384,"text":"7. Term. This Agreement shall commence on the Effective Date and continue for a period of three (3) years, unless earlier terminated by either Party upon thirty (30) days written notice. Notwithstanding the foregoing, the obligations of con"},"explanation":"Typical surviving obligations include confidentiality, indemnity, accrued payment obligations, and governing law. Missing any of these is common and worth confirming.","id":"TEMP-007-s1-3384","rule_id":"TEMP-007","rule_version":"1.2.0","severity":"info","source_citations":[],"title":"Survival list may be missing categories: indemnity, payment, governing law"},{"description":"Upon termination of this Agreement or upon written request by the Disclosing Party, the Receiving Party shall promptly return","document_position":4473,"excerpt":{"end_offset":4598,"section_id":"s1","start_offset":4473,"text":"9. Return or Destruction. Upon termination of this Agreement or upon written request by the Disclosing Party, the Receiving Party shall promptly return or destroy all Confidential Information, including all copies, extracts, and summaries thereof, and shall certify in writing tha"},"explanation":"Post-termination obligations typically include return or destruction of confidential materials, deletion of data, and a certificate of destruction.","id":"TERM-007-s1-4473","rule_id":"TERM-007","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Post-termination obligations enumerated"}],"playbook_id":"mutual-nda-deep","playbook_match_confidence":1,"playbook_match_reasoning":"forced via sidecar to mutual-nda-deep","result_hash":"a85c5541afc32a73535e181ac04ce938752737c5eb9b23d31de873d72260418e","source_file":{"name":"mutual-nda-deep-asymmetric-receiver-only-fail.txt","sha256":"4d09df3cc5d5e8c7bdcd64e5bdcce27fe60214e7c1179aadf53c374b264b3622","size_bytes":1},"version":"9.41.0"}