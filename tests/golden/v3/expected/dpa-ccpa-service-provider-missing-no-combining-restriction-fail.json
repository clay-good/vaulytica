25","rule_version":"1.0.0"}],"findings":[{"description":"No clause was found prohibiting use of personal information outside the specific business purpose.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"§ 1798.140(ag)(1)(B) requires the contract to prohibit the service provider from retaining, using, or disclosing personal information for any purpose other than the specific business purpose enumerated.","id":"USDPA-001-s1-0","recommendation":"Add: 'Service Provider shall not retain, use, or disclose personal information for any purpose other than the specific business purpose enumerated in this Agreement.'","rule_id":"USDPA-001","rule_version":"1.0.0","severity":"critical","source_citations":[{"id":"us-state-cal-civ-code-1798-140-ag-1-b-","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Cal. Civ. Code § 1798.140(ag)(1)(B)","source_url":"https://oag.ca.gov/privacy/ccpa"}],"title":"CCPA purpose-limitation clause missing"},{"description":"No clause was found requiring the same level of privacy protection.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"§ 1798.100(d) requires the contract to obligate the third party / service provider to comply with applicable obligations and provide the same level of privacy protection as required by the CCPA.","id":"USDPA-005-s1-0","recommendation":"Add: 'Service Provider shall comply with all applicable obligations under the CCPA and provide the same level of privacy protection as required by the CCPA.'","rule_id":"USDPA-005","rule_version":"1.0.0","severity":"critical","source_citations":[{"id":"us-state-cal-civ-code-1798-100-d-","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-0