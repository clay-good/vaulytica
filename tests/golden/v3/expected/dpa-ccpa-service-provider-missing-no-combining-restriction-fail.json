ssing"},{"description":"No clause was found identifying the type of personal data.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Each state requires the contract to specify the categories of personal data.","id":"USDPA-013-s1-0","recommendation":"Add an Annex listing the categories of personal data processed.","rule_id":"USDPA-013","rule_version":"1.0.0","severity":"critical","source_citations":[{"id":"us-state-va-code-59-1-579-colo-rev-stat-6-1-1305-similar","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Va. Code § 59.1-579 / Colo. Rev. Stat. § 6-1-1305 / similar","source_url":"https://law.lis.virginia.gov/vacodefull/title59.1/chapter53/"}],"title":"Type-of-data clause missing"},{"description":"No clause was found stating the duration of processing.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Every state's processor-contract statute requires the duration to be set out.","id":"USDPA-014-s1-0","recommendation":"State that processing continues for the term of the agreement.","rule_id":"USDPA-014","rule_version":"1.0.0","severity":"critical","source_citations":[{"id":"us-state-va-code-59-1-579-colo-rev-stat-6-1-1305-similar","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"Va. Code § 59.1-579 / Colo. Rev. Stat. § 6-1-1305 / similar","source_url":"https://law.lis.virginia.gov/vacodefull/title59.1/chapter53/"}],"title":"Duration-of-processing clause missing"},{"description":"No clause was found requiring confidentiality of authorized persons.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"E