apsed_ms":0,"fired":false,"rule_id":"USDPA-005","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-006","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-007","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-008","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-009","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-010","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-011","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-012","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-013","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-014","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-015","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-016","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-017","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-018","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-019","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-020","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-021","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-022","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-023","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-024","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-025","rule_version":"1.0.0"}],"findings":[{"description":"Worker / party is identified as California-based but the contract selects Delaware law.","document_position":8530,"excerpt":{"end_offset":8608,"section_id":"s1","start_offset":8530,"text":"Delaware"},"explanation":"Cal. Lab. Code § 925 voids out-of-state choice-of-law clauses in employment contracts entered into, modified, or extended after Jan. 1, 2017 — unless the employee was individually represented by counsel in negotiating that specific clause. Cal. Bus. & Prof. Code § 16600.5 (2024) extends similar reasoning to non-competes: they are unenforceable regardless of where signed if the worker is in California, and create a private right of action with attorneys' fees. This pattern is commonly used to evade California's strict non-compete prohibitions; courts (e.g., *Lyon v. Neustar*) routinely refuse to enforce it.","id":"CHOICE-011-s1-8530","recommendation":"Either change governing law to California, or include a §925 counsel-representation acknowledgment. Note that §16600.5 may render any non-compete unenforceable even with §925-compliant choice-of-law language.","rule_id":"CHOICE-011","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"stat-ca-bp-16600","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"California Business and Professions Code § 16600","source_url":"https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?lawCode=BPC&sectionNum=16600."}],"title":"Out-of-state choice-of-law on California-based party"},{"description":"Used but not defined: Customer Data, Two Million Dollars, Vendor Background.","document_position":7516,"excerpt":{"end_offset":7529,"section_id":"s1","start_offset":7516,"text":"Customer Data"},"explanation":"Title-Case phrases in a contract usually signal a defined term. When they aren't defined, readers must guess at the intended meaning. Either define them or use lowercase if the term is intended in its ordinary sense.","id":"STRUCT-006-s1-7516","recommendation":"Add a definition for each genuinely defined term, or change the casing if the phrase is being used in its ordinary sense.","rule_id":"STRUCT-006","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Undefined Title-Case terms: 3"},{"description":"The following references do not resolve to any section: Section 8(a), Section 8(a), Section 7, Section 6.","document_position":4770,"excerpt":{"end_offset":4782,"section_id":"s1","start_offset":4770,"text":"Section 8(a)"},"explanation":"A broken cross-reference can mean the referenced section was renumbered or deleted, or that a section reference was made up. Either way the reader has no way to follow the citation.","id":"STRUCT-007-s1-4770","recommendation":"Update each broken reference to point to the correct section, or delete it if it is no longer applicable.","rule_id":"STRUCT-007","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Unresolved cross-references: 4"},{"description":"The survival clause exists but does not name: IP ownership / assignment, indemnification.","document_position":2969,"excerpt":{"end_offset":3637,"section_id":"s1","start_offset":2969,"text":"6. Confidentiality. Each party (as \"Receiving Party\") shall hold in strict confidence all non-public information of the other party (as \"Disclosing Party\") designated as confidential or that reasonably should be understood to be confidential. Each party shall use such information"},"explanation":"Survival language is what keeps sticky obligations alive after a contract terminates. A survival clause that doesn't expressly enumerate the present-in-document confidentiality / IP / indemnity obligations creates ambiguity at the moment those obligations matter most — post-termination, when the contract has already ended.","id":"TEMP-012-s1-2969","recommendation":"Add explicit named references to the missing obligation(s): IP ownership / assignment, indemnification. Standard drafting names every sticky section by number or category in the survival clause.","rule_id":"TEMP-012","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Survival clause does not name 2 sticky obligations"},{"description":"Customer may terminate this Agreement without cause upon thirty (30) days prior written notice to Vendor. In the event of termination for convenience","document_position":7049,"excerpt":{"end_offset":7198,"section_id":"s1","start_offset":7049,"text":"10. Termination. (a) Termination for Cause. Either party may terminate this Agreement upon written notice if the other party materially breaches this Agreement and fails to cure such breach within thirty (30) days after receiving written no"},"explanation":"An asymmetric termination-for-convenience right is sometimes intentional (e.g., paid-up vendors), but the asymmetry should be deliberate.","id":"TERM-003-s1-7049","rule_id":"TERM-003","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Only one party may terminate for convenience"},{"description":"The contract does not state what happens upon termination.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no effect-of-termination clause)"},"explanation":"An effect-of-termination clause spells out the rights and obligations that survive, the return or destruction of materials, and the wind-down rules.","id":"TERM-005-s1-0","rule_id":"TERM-005","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No effect-of-termination clause detected"},{"description":"The document does not state where disputes must be brought.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no venue clause)"},"explanation":"Without a venue clause, default venue rules apply (in federal court, 28 U.S.C. § 1391). A clear forum-selection clause avoids ambiguity.","id":"CHOICE-003-s1-0","rule_id":"CHOICE-003","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"stat-28-usc-1391","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"28 U.S.C. § 1391 (venue generally)","source_url":"https://www.law.cornell.edu/uscode/text/28/1391"}],"title":"No venue / forum clause detected"},{"description":"The contract references data but does not separately allocate data ownership.","document_position":7516,"excerpt":{"end_offset":7529,"section_id":"s1","start_offset":7516,"text":"11. Data Portability and Return on Termination. Upon expiration or termination of this Agreement for any reason, Vendor shall: (a) promptly provide Customer with a complete, machine-readable export of all Customer Data in a standard, non-pr"},"explanation":"IP and data ownership are different. For SaaS, the customer typically owns its data; the vendor typically owns usage analytics. Address each explicitly.","id":"IPDATA-004-s1-7516","rule_id":"IPDATA-004","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Data ownership not separately addressed"},{"description":"Each party's aggregate liability to the other party for all claims arising out of or related to this Agreement shall not | The aggregate liability cap in Section 8(a) shall not apply to: (i) Vendor's indemnification obligations under Section 7 | This mutual exclusion of consequential damages shall not apply to breaches of confidentiality obligations or indemnifica","document_position":4840,"excerpt":{"end_offset":5167,"section_id":"s1","start_offset":4840,"text":"Each party's aggregate liability to the other party for all claims arising out of or related to this Agreement shall not exceed the greater of: (i) One Million Dollars ($1,000,000); or (ii) the total fees paid or payable by Customer to Vendor in the twelve (12) months immediately preceding the claim giving rise to liability."},"explanation":"Negative covenants restrict what a party may do. Surfacing them collectively makes it easier to check they are intended and consistent with the overall deal.","id":"OBLI-005-s1-4840","rule_id":"OBLI-005","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Negative covenants: 3"},{"description":"incidental, special, exemplary, or consequential damages","document_position":5599,"excerpt":{"end_offset":5655,"section_id":"s1","start_offset":5599,"text":"8. Limitation of Liability. (a) Aggregate Liability Cap. Each party's aggregate liability to the other party for all claims arising out of or related to this Agreement shall not exceed the greater of: (i) One Million Dollars ($1,000,000); o"},"explanation":"A waiver of consequential, special, incidental, and punitive damages is standard in commercial contracts. The waiver should be mutual unless deliberately asymmetric.","id":"RISK-007-s1-5599","rule_id":"RISK-007","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Consequential damages waiver present"},{"description":"commercial general liability insurance with limits of at least Two Million Dollars ($2,000,000","document_position":6174,"excerpt":{"end_offset":6268,"section_id":"s1","start_offset":6174,"text":"9. Vendor Insurance. During the term of this Agreement and for two (2) years thereafter, Vendor shall maintain, at its own expense: (a) commercial general liability insurance with limits of at least Two Million Dollars ($2,000,000) per occurrence and Five Million Dollars ($5,000,000) in the aggregate; (b) professional "},"explanation":"Insurance levels should match the deal size and risk. Common minimums are $1M per occurrence CGL and $2M E&O for services contracts.","id":"RISK-010-s1-6174","rule_id":"RISK-010","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Insurance requirements stated"},{"description":"Indemnity clause appears to be missing: notice, settlement consent.","document_position":3648,"excerpt":{"end_offset":3656,"section_id":"s1","start_offset":3648,"text":"7. Vendor Indemnification. Vendor shall indemnify, defend, and hold harmless Customer and its officers, directors, employees, and agents (\"Customer Indemnitees\") from and against any third-party claim, suit, or proceeding arising out of or relating to: (a) any allegation that the"},"explanation":"A complete indemnity clause specifies (a) the timeline and form for notice of a claim, (b) which party controls defense, and (c) whether settlement requires consent.","id":"RISK-011-s1-3648","rule_id":"RISK-011","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Indemnity procedural elements missing: notice, settlement consent"},{"description":"confidentiality obligations no less protective than this Agreement. These obligations survive termination of this Agreement for three (3) year","document_position":3427,"excerpt":{"end_offset":3569,"section_id":"s1","start_offset":3427,"text":"6. Confidentiality. Each party (as \"Receiving Party\") shall hold in strict confidence all non-public information of the other party (as \"Disclosing Party\") designated as confidential or that reasonably should be understood to be confidentia"},"explanation":"Typical post-termination confidentiality terms run 3–5 years for general information, with a perpetual duty for trade secrets. Verify the term matches the sensitivity of the information.","id":"RISK-014-s1-3427","rule_id":"RISK-014","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Confidentiality term length stated"},{"description":"Vaulytica did not find a Definitions section or any inline-defined terms.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no definitions located)"},"explanation":"Most non-trivial contracts capitalize defined terms and either set them out in a Definitions section or define them inline (\"X\" means …). Their absence is not by itself a problem, but downstream rules that check for use of specific defined terms will be skipped.","id":"STRUCT-004-s1-0","rule_id":"STRUCT-004","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"No defined terms detected"},{"description":"Provisions are stated to survive termination.","document_position":3513,"excerpt":{"end_offset":3532,"section_id":"s1","start_offset":3513,"text":"6. Confidentiality. Each party (as \"Receiving Party\") shall hold in strict confidence all non-public information of the other party (as \"Disclosing Party\") designated as confidential or that reasonably should be understood to be confidentia"},"explanation":"A survival clause names the obligations that outlast termination — typically confidentiality, indemnity, payment obligations accrued before termination, and choice of law.","id":"TEMP-006-s1-3513","rule_id":"TEMP-006","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Survival clause present"},{"description":"Survival clause does not appear to include: indemnity, payment, governing law.","document_position":3513,"excerpt":{"end_offset":3532,"section_id":"s1","start_offset":3513,"text":"6. Confidentiality. Each party (as \"Receiving Party\") shall hold in strict confidence all non-public information of the other party (as \"Disclosing Party\") designated as confidential or that reasonably should be understood to be confidentia"},"explanation":"Typical surviving obligations include confidentiality, indemnity, accrued payment obligations, and governing law. Missing any of these is common and worth confirming.","id":"TEMP-007-s1-3513","rule_id":"TEMP-007","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Survival list may be missing categories: indemnity, payment, governing law"}],"playbook_id":"mutual-nda","playbook_match_confidence":1,"playbook_match_reasoning":"forced via sidecar to msa-customer-deep","result_hash":"f10ac1facf4c460f52718b2e5466e6070cb3f013c6877cfdf9f19d11c2fd366e","source_file":{"name":"msa-customer-deep-minimal-pass.txt","sha256":"96bbe2f2705226ed4ee2682c798ecf06ef1260e52a2c4347fde5eb0f30f75732","size_bytes":1},"version":"0.1.0"}