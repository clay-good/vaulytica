s":0,"fired":false,"rule_id":"TRANSFER-020","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-001","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-002","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-003","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-004","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-005","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-006","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-007","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-008","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-009","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-010","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-011","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-012","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-013","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-014","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-015","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-016","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-017","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-018","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-019","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-020","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-021","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-022","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-023","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-024","rule_version":"1.0.0"},{"elapsed_ms":0,"fired":false,"rule_id":"USDPA-025","rule_version":"1.0.0"}],"findings":[{"description":"use Customer Data, including any derived or transformed forms thereof, to train","document_position":1146,"excerpt":{"end_offset":1225,"section_id":"s1","start_offset":1146,"text":"ning on Customer Data. Vendor shall not use Customer Data, including any derived or transformed forms thereof, to train, fine-tune, retrain, improve, or otherwise modify any AI model, including Vendor's proprietary models or any third-party foundational model. This prohibition applies regardless of whether the Customer"},"explanation":"Granting the vendor a license to train ML / AI models on Customer Data creates several distinct problems: (1) under GDPR, training is processing that requires a lawful basis the customer typically cannot grant on behalf of the data subjects; (2) the right-to-erasure under Art. 17 is practically impossible because a trained model cannot unlearn specific training examples; (3) under HIPAA, GLBA, FERPA the training-license breaches the customer's downstream regulatory obligations; (4) downstream IP exposure from training-data litigation (*Andersen v. Stability AI*, *Getty Images*) flows back via indemnity.","id":"IPDATA-009-s1-1146","recommendation":"Strike the training license entirely, or narrow it dramatically: (a) only de-identified / aggregated data, (b) only for operating the Service for that customer (not 'developing' the vendor's other services), (c) explicit opt-in rather than buried-in-TOS license, (d) carve-out for regulated data categories (PII, PHI, financial data, education records).","rule_id":"IPDATA-009","rule_version":"1.0.0","severity":"critical","source_citations":[],"title":"AI / model-training rights over Customer Data"},{"description":"AI feature inventory + on-by-default-vs-opt-in + on-prem-vs-third-party-model disclosures not all present.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"EU AI Act Article 50 + FTC consumer-protection posture both require clear disclosure of AI use.","id":"ADDENDA-012-s1-0","recommendation":"List the AI features, their default-on / opt-in status, and the model host (on-prem vs OpenAI / Anthropic / Google / etc.).","rule_id":"ADDENDA-012","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"addenda-eu-ai-act-art-50-transparency-","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"EU AI Act (Art. 50 transparency)","source_url":"https://eur-lex.europa.eu/eli/reg/2024/1689/oj"}],"title":"AI transparency disclosures missing"},{"description":"No clause allocates IP ownership of Outputs as between Customer and Vendor.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Output ownership is a frequent dispute and varies materially across vendors; allocation must be explicit.","id":"ADDENDA-013-s1-0","recommendation":"Allocate explicitly: e.g., 'As between the parties, Customer owns Outputs to the extent permitted by law; Vendor retains its models and tooling.'","rule_id":"ADDENDA-013","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"addenda-nist-ai-rmf-consensus-practice-not-statute-","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"NIST AI RMF (consensus practice, not statute)","source_url":"https://www.nist.gov/itl/ai-risk-management-framework"}],"title":"IP ownership of AI Outputs unallocated"},{"description":"No AI-subprocessor list (named or by URL) was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"When AI features are powered by a third-party model provider, GDPR Art. 28(2) requires authorisation and disclosure.","id":"ADDENDA-015-s1-0","recommendation":"List AI subprocessors by name (e.g., OpenAI, Anthropic, Google, Cohere) or reference a maintained URL.","rule_id":"ADDENDA-015","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"addenda-gdpr-article-28-2-subprocessor-authorisation-","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"GDPR Article 28(2) (subprocessor authorisation)","source_url":"https://www.nist.gov/"}],"title":"AI subprocessor disclosure missing"},{"description":"No obligation to delete fine-tuning / training data on termination was found.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(clause absent from the document)"},"explanation":"Without deletion, Customer Data can persist in vendor model weights indefinitely.","id":"ADDENDA-016-s1-0","recommendation":"Add: 'On termination, Vendor shall delete all fine-tuning datasets derived from Customer Data within 30 days; trained model weights derived from Customer Data shall be deleted within 90 days.'","rule_id":"ADDENDA-016","rule_version":"1.0.0","severity":"warning","source_citations":[{"id":"addenda-gdpr-art-17-right-to-erasure-","license":"Public domain or regulator re-use","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-12T00:00:00Z","source":"GDPR Art. 17 (right to erasure)","source_url":"https://www.nist.gov/"}],"title":"Fine-tuning data deletion-on-termination missing"},{"description":"Vaulytica did not find a governing-law clause.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no governing-law clause)"},"explanation":"A governing-law clause picks the legal system that interprets the contract. Without it, courts apply conflict-of-laws rules, which may produce unexpected results.","id":"CHOICE-001-s1-0","rule_id":"CHOICE-001","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No governing-law clause detected"},{"description":"Vaulytica did not find a limitation-of-liability clause.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no LoL clause)"},"explanation":"Without a limitation-of-liability clause, exposure is bounded only by what the parties can prove in damages. Most commercial contracts cap liability.","id":"RISK-005-s1-0","rule_id":"RISK-005","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No limitation-of-liability clause detected"},{"description":"Used but not defined: Customer Data.","document_position":558,"excerpt":{"end_offset":571,"section_id":"s1","start_offset":558,"text":"Customer Data"},"explanation":"Title-Case phrases in a contract usually signal a defined term. When they aren't defined, readers must guess at the intended meaning. Either define them or use lowercase if the term is intended in its ordinary sense.","id":"STRUCT-006-s1-558","recommendation":"Add a definition for each genuinely defined term, or change the casing if the phrase is being used in its ordinary sense.","rule_id":"STRUCT-006","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Undefined Title-Case terms: 1"},{"description":"The following references do not resolve to any section: Section 1, Section 6, Section 9.","document_position":1019,"excerpt":{"end_offset":1028,"section_id":"s1","start_offset":1019,"text":"Section 1"},"explanation":"A broken cross-reference can mean the referenced section was renumbered or deleted, or that a section reference was made up. Either way the reader has no way to follow the citation.","id":"STRUCT-007-s1-1019","recommendation":"Update each broken reference to point to the correct section, or delete it if it is no longer applicable.","rule_id":"STRUCT-007","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Unresolved cross-references: 3"},{"description":"The survival clause exists but does not name: indemnification.","document_position":1084,"excerpt":{"end_offset":1646,"section_id":"s1","start_offset":1084,"text":"2. Prohibition on Training on Customer Data. Vendor shall not use Customer Data, including any derived or transformed forms thereof, to train, fine-tune, retrain, improve, or otherwise modify any AI model, including Vendor's proprietary models or any third-party foundational mode"},"explanation":"Survival language is what keeps sticky obligations alive after a contract terminates. A survival clause that doesn't expressly enumerate the present-in-document confidentiality / IP / indemnity obligations creates ambiguity at the moment those obligations matter most — post-termination, when the contract has already ended.","id":"TEMP-012-s1-1084","recommendation":"Add explicit named references to the missing obligation(s): indemnification. Standard drafting names every sticky section by number or category in the survival clause.","rule_id":"TEMP-012","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"Survival clause does not name 1 sticky obligation"},{"description":"The contract does not state a path to terminate for material breach.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no for-cause termination)"},"explanation":"Without a for-cause termination path, parties must rely on common-law material-breach doctrines, which are jurisdiction-dependent.","id":"TERM-002-s1-0","rule_id":"TERM-002","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No termination-for-cause clause detected"},{"description":"The contract does not state what happens upon termination.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no effect-of-termination clause)"},"explanation":"An effect-of-termination clause spells out the rights and obligations that survive, the return or destruction of materials, and the wind-down rules.","id":"TERM-005-s1-0","rule_id":"TERM-005","rule_version":"1.0.0","severity":"warning","source_citations":[],"title":"No effect-of-termination clause detected"},{"description":"The document does not state where disputes must be brought.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no venue clause)"},"explanation":"Without a venue clause, default venue rules apply (in federal court, 28 U.S.C. § 1391). A clear forum-selection clause avoids ambiguity.","id":"CHOICE-003-s1-0","rule_id":"CHOICE-003","rule_version":"1.0.0","severity":"info","source_citations":[{"id":"stat-28-usc-1391","license":"Public domain (US government work)","license_url":"https://www.usa.gov/government-works","retrieved_at":"2026-05-11T00:00:00Z","source":"28 U.S.C. § 1391 (venue generally)","source_url":"https://www.law.cornell.edu/uscode/text/28/1391"}],"title":"No venue / forum clause detected"},{"description":"The contract references data but does not separately allocate data ownership.","document_position":558,"excerpt":{"end_offset":571,"section_id":"s1","start_offset":558,"text":"This Artificial Intelligence Use Addendum (\"AI Addendum\") is entered into as of March 1, 2026, by and between Stark Enterprises LLC, a Delaware limited liability company (\"Customer\"), and Wayne Analytics Inc., a California corporation (\"Ven"},"explanation":"IP and data ownership are different. For SaaS, the customer typically owns its data; the vendor typically owns usage analytics. Address each explicitly.","id":"IPDATA-004-s1-558","rule_id":"IPDATA-004","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Data ownership not separately addressed"},{"description":"Vendor shall not use Customer Data, including any derived or transformed forms thereof, to train, fine-tune, retrain, im | Vendor shall not subject any Customer Data to AI processing unless Customer has affirmatively consented to such processi","document_position":1128,"excerpt":{"end_offset":1366,"section_id":"s1","start_offset":1128,"text":"Vendor shall not use Customer Data, including any derived or transformed forms thereof, to train, fine-tune, retrain, improve, or otherwise modify any AI model, including Vendor's proprietary models or any third-party foundational model."},"explanation":"Negative covenants restrict what a party may do. Surfacing them collectively makes it easier to check they are intended and consistent with the overall deal.","id":"OBLI-005-s1-1128","rule_id":"OBLI-005","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Negative covenants: 2"},{"description":"Indemnity clause appears to be missing: notice, defense control, settlement consent.","document_position":3123,"excerpt":{"end_offset":3131,"section_id":"s1","start_offset":3123,"text":"6. Vendor Indemnity for AI-Generated IP Infringement. Vendor shall indemnify, defend, and hold harmless Customer and its affiliates, officers, directors, employees, and agents from and against any and all claims, damages, losses, costs, and expenses (including reasonable attorney"},"explanation":"A complete indemnity clause specifies (a) the timeline and form for notice of a claim, (b) which party controls defense, and (c) whether settlement requires consent.","id":"RISK-011-s1-3123","rule_id":"RISK-011","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Indemnity procedural elements missing: notice, defense control, settlement consent"},{"description":"Infringement. Vendor shall indemnif","document_position":3096,"excerpt":{"end_offset":3131,"section_id":"s1","start_offset":3096,"text":"6. Vendor Indemnity for AI-Generated IP Infringement. Vendor shall indemnify, defend, and hold harmless Customer and its affiliates, officers, directors, employees, and agents from and against any and all claims, damages, losses, costs, and expenses (including reasonable attorney"},"explanation":"IP indemnity protects against third-party infringement claims. Standard scope is third-party claims only; broader scope shifts more risk to the indemnifying party.","id":"RISK-012-s1-3096","rule_id":"RISK-012","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"IP indemnity present"},{"description":"Vaulytica did not find a Definitions section or any inline-defined terms.","document_position":0,"excerpt":{"end_offset":0,"section_id":"s1","start_offset":0,"text":"(no definitions located)"},"explanation":"Most non-trivial contracts capitalize defined terms and either set them out in a Definitions section or define them inline (\"X\" means …). Their absence is not by itself a problem, but downstream rules that check for use of specific defined terms will be skipped.","id":"STRUCT-004-s1-0","rule_id":"STRUCT-004","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"No defined terms detected"},{"description":"Earliest date 2026-01-15 precedes the next date 2026-03-01 by 45 days.","document_position":384,"excerpt":{"end_offset":400,"section_id":"s1","start_offset":384,"text":"January 15, 2026"},"explanation":"A contract dated significantly before its other date references may be intentionally back-dated. Confirm the intent before signing.","id":"TEMP-002-s1-384","rule_id":"TEMP-002","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Earliest dated reference is far before other dates"},{"description":"Provisions are stated to survive termination.","document_position":1596,"excerpt":{"end_offset":1620,"section_id":"s1","start_offset":1596,"text":"2. Prohibition on Training on Customer Data. Vendor shall not use Customer Data, including any derived or transformed forms thereof, to train, fine-tune, retrain, improve, or otherwise modify any AI model, including Vendor's proprietary mod"},"explanation":"A survival clause names the obligations that outlast termination — typically confidentiality, indemnity, payment obligations accrued before termination, and choice of law.","id":"TEMP-006-s1-1596","rule_id":"TEMP-006","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Survival clause present"},{"description":"Survival clause does not appear to include: confidentiality, indemnity, payment, governing law.","document_position":1596,"excerpt":{"end_offset":1620,"section_id":"s1","start_offset":1596,"text":"2. Prohibition on Training on Customer Data. Vendor shall not use Customer Data, including any derived or transformed forms thereof, to train, fine-tune, retrain, improve, or otherwise modify any AI model, including Vendor's proprietary mod"},"explanation":"Typical surviving obligations include confidentiality, indemnity, accrued payment obligations, and governing law. Missing any of these is common and worth confirming.","id":"TEMP-007-s1-1596","rule_id":"TEMP-007","rule_version":"1.0.0","severity":"info","source_citations":[],"title":"Survival list may be missing categories: confidentiality, indemnity, payment, governing law"}],"playbook_id":"ai-addendum","playbook_match_confidence":1,"playbook_match_reasoning":"forced via sidecar to ai-addendum","result_hash":"08f5d8cf43141d3dc2caa333fb41f9cd19adec5c4b4a7b4a8cec961b5ca8dda8","source_file":{"name":"ai-addendum-missing-transparency-disclosures-fail.txt","sha256":"326723d49da605900c4e93243f2764b36f7e985d7eb4bc3001eb1e2e48a89c3b","size_bytes":1},"version":"9.41.0"}