{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vaulytica.com/playbook.schema.json",
  "title": "Vaulytica custom playbook",
  "description": "A user-supplied, client-side playbook encoding a team's own contract-review positions (spec-v6 Part II). The Zod schema in src/playbooks/custom-playbook.ts is authoritative; this JSON Schema is an informative mirror for editor autocomplete and external tooling.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog_version", "id", "name", "description"],
  "properties": {
    "schema_version": {
      "description": "Version of this playbook schema format.",
      "const": "1.0"
    },
    "catalog_version": {
      "description": "The built-in rule-catalog version this playbook targets.",
      "type": "string",
      "minLength": 1
    },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "mode": {
      "description": "augment = built-in catalog + custom positions (default); replace = custom positions only.",
      "enum": ["augment", "replace"]
    },
    "party_roles": {
      "type": "array",
      "description": "The party roles this playbook's positions can be evaluated as, e.g. [\"vendor\", \"customer\"] (add-negotiation-ladder-playbooks). Required when any position declares role_variants; --role must name one of these.",
      "items": { "type": "string", "minLength": 1 }
    },
    "rule_selection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "exclude": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "rule_overrides": {
      "description": "Per-built-in-rule severity override / skip, keyed by rule id.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "severity": { "$ref": "#/$defs/severity" },
          "skip": { "type": "boolean" }
        }
      }
    },
    "thresholds": {
      "description": "Named numeric threshold parameters the team's positions reference.",
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "required_clauses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "severity"],
        "properties": {
          "category": { "type": "string", "minLength": 1 },
          "severity": { "$ref": "#/$defs/severity" }
        }
      }
    },
    "custom_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/customRule" }
    },
    "negotiation_positions": {
      "type": "array",
      "description": "Tiered negotiation positions (spec-v10): which rung of the team's ideal/acceptable ladder the draft meets, on each negotiable dimension. Advisory posture, outside result_hash.",
      "items": { "$ref": "#/$defs/negotiationPosition" }
    }
  },
  "$defs": {
    "severity": { "enum": ["critical", "warning", "info"] },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "customRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "severity", "assert"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "assert": { "$ref": "#/$defs/predicate" },
        "citation": { "$ref": "#/$defs/citation" }
      }
    },
    "negotiationPosition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "ideal", "acceptable"],
      "description": "A tiered position on one negotiable dimension. `ideal` is the stricter predicate, `acceptable` the floor; both reuse the predicate DSL.",
      "properties": {
        "dimension": { "type": "string", "minLength": 1 },
        "ideal": { "$ref": "#/$defs/predicate" },
        "acceptable": { "$ref": "#/$defs/predicate" },
        "rungs": {
          "type": "array",
          "maxItems": 8,
          "description": "Optional intermediate rungs between ideal and the acceptable floor (add-negotiation-ladder-playbooks), ordered best-first. Detail only: they refine which rung above the floor the draft met and never change the reported tier or posture_hash.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "predicate"],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "predicate": { "$ref": "#/$defs/predicate" }
            }
          }
        },
        "guidance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ideal": { "type": "string", "minLength": 1 },
            "acceptable": { "type": "string", "minLength": 1 },
            "walk_away": { "type": "string", "minLength": 1 }
          }
        },
        "approved_language": {
          "type": "string",
          "minLength": 1,
          "description": "The team's own pre-approved fallback language, quoted beside a below-floor position (never generated). Advisory; outside posture_hash."
        },
        "role_variants": {
          "type": "object",
          "description": "Per-party-role ladder overrides (add-negotiation-ladder-playbooks), keyed by a role in the playbook's party_roles. When --role X is selected and role_variants[X] exists, its ladder replaces the base ideal/acceptable/rungs for this dimension.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ideal", "acceptable"],
            "properties": {
              "ideal": { "$ref": "#/$defs/predicate" },
              "acceptable": { "$ref": "#/$defs/predicate" },
              "rungs": {
                "type": "array",
                "maxItems": 8,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["label", "predicate"],
                  "properties": {
                    "label": { "type": "string", "minLength": 1 },
                    "predicate": { "$ref": "#/$defs/predicate" }
                  }
                }
              },
              "guidance": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "ideal": { "type": "string", "minLength": 1 },
                  "acceptable": { "type": "string", "minLength": 1 },
                  "walk_away": { "type": "string", "minLength": 1 }
                }
              },
              "approved_language": { "type": "string", "minLength": 1 }
            }
          }
        },
        "size_bands": {
          "type": "array",
          "maxItems": 8,
          "description": "Deal-size bands (add-negotiation-ladder-playbooks): the band with the highest min_value at or below the resolved --deal-value replaces this dimension's base ladder. The base is the default when none applies or no deal value is known.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["min_value", "ideal", "acceptable"],
            "properties": {
              "min_value": { "type": "number", "minimum": 0 },
              "label": { "type": "string", "minLength": 1 },
              "ideal": { "$ref": "#/$defs/predicate" },
              "acceptable": { "$ref": "#/$defs/predicate" },
              "rungs": {
                "type": "array",
                "maxItems": 8,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["label", "predicate"],
                  "properties": {
                    "label": { "type": "string", "minLength": 1 },
                    "predicate": { "$ref": "#/$defs/predicate" }
                  }
                }
              },
              "guidance": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "ideal": { "type": "string", "minLength": 1 },
                  "acceptable": { "type": "string", "minLength": 1 },
                  "walk_away": { "type": "string", "minLength": 1 }
                }
              },
              "approved_language": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "predicate": {
      "description": "A condition that must hold for a compliant document; the rule fires a finding when it is false.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "const": "clause_present" },
            "pattern": { "type": "string", "minLength": 1 },
            "section_heading": { "type": "string", "minLength": 1 }
          },
          "anyOf": [{ "required": ["pattern"] }, { "required": ["section_heading"] }]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "const": "clause_absent" },
            "pattern": { "type": "string", "minLength": 1 },
            "section_heading": { "type": "string", "minLength": 1 }
          },
          "anyOf": [{ "required": ["pattern"] }, { "required": ["section_heading"] }]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "metric", "comparator", "value"],
          "properties": {
            "kind": { "const": "numeric_threshold" },
            "metric": {
              "enum": [
                "liability_cap_multiple",
                "liability_cap_amount",
                "notice_period_days",
                "term_length_days",
                "payment_term_days",
                "cure_period_days",
                "auto_renewal_notice_days",
                "indemnity_cap_amount",
                "uptime_sla_percent"
              ]
            },
            "comparator": { "enum": ["gte", "lte", "gt", "lt", "eq"] },
            "value": { "type": "number" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "term"],
          "properties": {
            "kind": { "const": "defined_term_present" },
            "term": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "allowed"],
          "properties": {
            "kind": { "const": "governing_law_in" },
            "allowed": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "const": "cross_ref_resolves" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "clause"],
          "properties": {
            "kind": { "const": "clause_mutual" },
            "clause": { "enum": ["indemnification", "termination", "confidentiality"] },
            "pattern": { "type": "string", "minLength": 1 },
            "section_heading": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
